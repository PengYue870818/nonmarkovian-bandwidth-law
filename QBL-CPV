def validate_paper_alignment(results_SM, results_LM, outdir, tag='validation_report_msis'):
    ensure_dir(outdir)
    rows = {'group': [], 'metric': [], 'value': [], 'threshold': [], 'pass': []}
    def rec(gr, m, val, thr, ok):
        rows['group'].append(gr); rows['metric'].append(m); rows['value'].append(val); rows['threshold'].append(thr); rows['pass'].append(bool(ok))
    def agg(vals, fn=np.nanmax):
        a = np.array(vals, dtype=float)
        a = a[np.isfinite(a)]
        if a.size == 0:
            return np.nan
        return float(fn(a))
    sm_alpha = [r.get('alpha', np.nan) for r in results_SM]
    lm_alpha = [r.get('alpha', np.nan) for r in results_LM]
    rec('SM', 'alpha_min', float(np.nanmin(sm_alpha)) if np.any(np.isfinite(sm_alpha)) else np.nan, 0.9, (np.nanmin(sm_alpha) >= 0.9 if np.any(np.isfinite(sm_alpha)) else False))
    rec('SM', 'alpha_max', float(np.nanmax(sm_alpha)) if np.any(np.isfinite(sm_alpha)) else np.nan, 1.1, (np.nanmax(sm_alpha) <= 1.1 if np.any(np.isfinite(sm_alpha)) else False))
    rec('LM', 'alpha_min', float(np.nanmin(lm_alpha)) if np.any(np.isfinite(lm_alpha)) else np.nan, 0.9, (np.nanmin(lm_alpha) >= 0.9 if np.any(np.isfinite(lm_alpha)) else False))
    rec('LM', 'alpha_max', float(np.nanmax(lm_alpha)) if np.any(np.isfinite(lm_alpha)) else np.nan, 1.1, (np.nanmax(lm_alpha) <= 1.1 if np.any(np.isfinite(lm_alpha)) else False))
    sm_duh = [r.get('duhamel_norm_err', np.nan) for r in results_SM]
    lm_duh = [r.get('duhamel_norm_err', np.nan) for r in results_LM]
    sm_duh_max = agg(sm_duh, np.nanmax); lm_duh_max = agg(lm_duh, np.nanmax)
    rec('SM', 'max_norm_err(duhamel)', sm_duh_max, 5e-3, (np.isfinite(sm_duh_max) and sm_duh_max <= 5e-3))
    rec('LM', 'max_norm_err(duhamel)', lm_duh_max, 5e-3, (np.isfinite(lm_duh_max) and lm_duh_max <= 5e-3))
    save_csv(os.path.join(outdir, f"{tag}.csv"),
             ['group', 'metric', 'value', 'threshold', 'pass'],
             [rows['group'], rows['metric'], rows['value'], rows['threshold'], rows['pass']])
    return all(rows['pass']) if rows['pass'] else False

def get_Omega_S_for_tag(tag, specs, synthetic_params):
    for sp in specs:
        if sp['tag'] == tag and sp['kind'] == 'file':
            f_Hz, S = read_two_column_csv(sp['file'], sp['fx'], sp['fy'])
            f_Hz, S = dedup_average_by_freq(f_Hz, S)
            return 2.0 * np.pi * f_Hz, S
    if tag == synthetic_params['tag']:
        Npts = synthetic_params['Npts']
        fmin = synthetic_params['fmin']; fmax = synthetic_params['fmax']
        f_Hz = np.exp(np.linspace(np.log(fmin), np.log(fmax), Npts))
        Omega = 2.0 * np.pi * f_Hz
        S = synthetic_params['A'] * (1.0 / np.maximum(f_Hz, 1e-30)) ** synthetic_params['gamma']
        return Omega, S
    return None, None

