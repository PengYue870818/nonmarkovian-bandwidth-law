import os
import csv
import numpy as np
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
from scipy.interpolate import interp1d
from scipy.stats import t

def ensure_dir(d):
    if d and (not os.path.isdir(d)):
        os.makedirs(d, exist_ok=True)
    return d

def save_csv(path, headers, columns):
    arrays = []
    lens = []
    for c in columns:
        if np.isscalar(c) and not isinstance(c, str):
            arr = np.array([c])
        else:
            arr = np.array(c, dtype=object).reshape(-1)
        arrays.append(arr)
        lens.append(arr.shape[0])
    n = max(lens) if lens else 0
    bcols = []
    for arr in arrays:
        if arr.shape[0] == n:
            bcols.append(arr)
        elif arr.shape[0] == 1 and n > 1:
            bcols.append(np.full(n, arr[0], dtype=object))
        else:
            pad_len = n - arr.shape[0]
            if pad_len > 0:
                arr = np.concatenate([arr, np.full(pad_len, np.nan, dtype=object)], axis=0)
            bcols.append(arr)
    ensure_dir(os.path.dirname(path))
    with open(path, "w", newline="") as f:
        w = csv.writer(f)
        w.writerow(headers)
        for i in range(n):
            row = []
            for col in bcols:
                val = col[i] if col.shape[0] > 0 else np.nan
                try:
                    row.append(float(val))
                except (TypeError, ValueError):
                    row.append(str(val))
            w.writerow(row)

def filter_rectangular_double_sided(omega, delta_t):
    w = np.asarray(omega, dtype=float) * float(delta_t)
    w2 = np.maximum(w * w, 1e-300)
    return 4.0 * (np.sin(0.5 * w) ** 2) / w2

def H_overlap_fraction(omega, F, S, omega_up):
    mask = (omega > 0) & (omega <= omega_up)
    om = omega[mask]
    if om.size == 0:
        return np.array([omega_up]), np.array([0.0]), 0.0
    integrand = F[mask] * S[mask]
    H = np.zeros_like(om)
    H[1:] = np.cumsum(0.5 * (integrand[1:] + integrand[:-1]) * (om[1:] - om[:-1])) / np.pi
    total = H[-1] if H.size > 0 else 1.0
    frac = H / max(total, 1e-300)
    return om, frac, total

def Wplus_fraction(omega, F, omega_up):
    mask = (omega > 0) & (omega <= omega_up)
    om = omega[mask]
    if om.size == 0:
        return np.array([omega_up]), np.array([0.0]), 0.0
    integrand = F[mask]
    Wp = np.zeros_like(om)
    Wp[1:] = np.cumsum(0.5 * (integrand[1:] + integrand[:-1]) * (om[1:] - om[:-1])) / (2.0 * np.pi)
    total = Wp[-1] if Wp.size > 0 else 1.0
    frac = Wp / max(total, 1e-300)
    return om, frac, total

def invert_quantile(om, frac, kappa):
    kappa = float(np.clip(kappa, 1e-9, 1.0 - 1e-9))
    return float(np.interp(kappa, frac, om))

def log_span(omega_min, omega_max):
    if omega_max <= omega_min:
        return 0.0
    return float(np.log(omega_max / omega_min))

def band_C_F(omega, F, omega_min, omega_max):
    mask = (omega >= omega_min) & (omega <= omega_max)
    if not np.any(mask):
        return 1.0
    om = omega[mask]
    if om.size < 2:
        return 1.0
    dln = np.log(om[1] / om[0])
    lnspan = log_span(omega_min, omega_max)
    CF = ((1.0 / (2.0 * np.pi)) * np.sum((om * F[mask]) * dln)) / max(lnspan, 1e-300)
    return float(CF) if (CF > 0 and np.isfinite(CF)) else 1.0

def get_calibrated_F_for_band(omega, F_raw, omega_min, omega_max):
    mask = (omega >= omega_min) & (omega <= omega_max)
    if np.sum(mask) < 2:
        return F_raw, 1.0
    om = omega[mask]
    dln = np.log(om[1] / om[0])
    lnspan = log_span(omega_min, omega_max)
    C_tilde = ((1.0 / (2.0 * np.pi)) * np.sum((om * F_raw[mask]) * dln)) / max(lnspan, 1e-300)
    C_tilde = max(float(C_tilde), 1e-300)
    F_eff = F_raw / C_tilde
    return F_eff, C_tilde

def lever_integral_log(omega, F, S_over_S0, omega_min, omega_max):
    mask = (omega >= omega_min) & (omega <= omega_max)
    if not np.any(mask):
        return 0.0
    om = omega[mask]
    if om.size < 2:
        return 0.0
    dln = np.log(om[1] / om[0])
    CF = band_C_F(omega, F, omega_min, omega_max)
    q = (((omega * F) / (2.0 * np.pi)) * (S_over_S0)) / max(CF, 1e-300)
    lever = float(np.sum(q[mask] * dln))
    return lever

def dedup_average_by_freq(f, s):
    f = np.asarray(f, dtype=float).ravel()
    s = np.asarray(s, dtype=float).ravel()
    mask = np.isfinite(f) & np.isfinite(s) & (f > 0)
    f = f[mask]; s = s[mask]
    idx = np.argsort(f)
    f = f[idx]; s = s[idx]
    out_f = []
    out_s = []
    i = 0
    n = len(f)
    while i < n:
        j = i + 1
        while j < n and np.isclose(f[j], f[i], rtol=1e-12, atol=1e-9):
            j += 1
        out_f.append(np.mean(f[i:j]))
        out_s.append(np.mean(s[i:j]))
        i = j
    return np.array(out_f), np.array(out_s)

def read_two_column_csv(path, fx_name, fy_name):
    xs = []
    ys = []
    with open(path, "r", newline="") as f:
        rd = csv.DictReader(f)
        for row in rd:
            try:
                x = float(row[fx_name]); y = float(row[fy_name])
                xs.append(x); ys.append(y)
            except Exception:
                continue
    return np.array(xs, dtype=float), np.array(ys, dtype=float)

def inequality_min_gap(omH, Hfrac, omW, Wfrac, trim_frac=0.15):
    if (omH.size < 4) or (omW.size < 4):
        return np.nan
    i0 = int(np.floor(trim_frac * omH.size))
    i1 = int(np.ceil((1.0 - trim_frac) * omH.size))
    if i1 <= i0 + 1:
        return np.nan
    omc = omH[i0:i1]
    Hc = np.interp(omc, omH, Hfrac)
    Wc = np.interp(omc, omW, Wfrac)
    return float(np.min(Hc - Wc))

def band_log_slope(metric_vals, omega_band):
    om = np.array(omega_band, dtype=float).ravel()
    y = np.maximum(np.array(metric_vals, dtype=float).ravel(), 1e-300)
    if om.size < 3:
        return 0.0
    lnw = np.log(om)
    lny = np.log(y)
    dln = lnw[1] - lnw[0]
    slope = np.gradient(lny, dln)
    return float(np.max(np.abs(slope)))

def compute_Lq_from_q(omega_band, q_vals):
    om = np.array(omega_band, dtype=float).ravel()
    q = np.maximum(np.array(q_vals, dtype=float).ravel(), 1e-300)
    if om.size < 3 or q.size < 3:
        return 0.0
    lnw = np.log(om)
    lnq = np.log(q)
    dln = lnw[1] - lnw[0]
    dlnq = np.gradient(lnq, dln)
    return float(np.max(np.abs(dlnq)))

def compute_band_metrics_from_arrays(omega, Fg, Sg, Omega_min_used, omega_upper):
    mask = (omega >= Omega_min_used) & (omega <= omega_upper)
    if np.sum(mask) < 3:
        return None
    om = omega[mask]
    dln = np.log(om[1] / om[0])
    Delta = log_span(Omega_min_used, omega_upper)
    CF = band_C_F(omega, Fg, Omega_min_used, omega_upper)
    idx0 = np.where(omega >= Omega_min_used)[0]
    if idx0.size == 0:
        return None
    i0 = idx0[0]
    S0 = max(Sg[i0], 1e-300)
    q_full = (((omega * Fg) / (2.0 * np.pi)) * (Sg / S0)) / max(CF, 1e-300)
    q_band = q_full[mask]
    lever = float(np.sum(q_band * dln))
    alpha = lever / max(Delta, 1e-300)
    S_norm = Sg[mask] / S0
    F_norm_for_slope = (om * Fg[mask]) / (2.0 * np.pi)
    L_S = band_log_slope(S_norm, om)
    L_F = band_log_slope(F_norm_for_slope, om)
    LSDelta = L_S * Delta
    LFDelta = L_F * Delta
    L_q = compute_Lq_from_q(om, q_band)
    return Delta, lever, alpha, LSDelta, LFDelta, om, q_band, L_S, L_F, L_q

def interpolate_loglog(Omega_data, S_data, Omega_grid):
    Svals_clip = np.maximum(S_data, 1e-30)
    f_interp = interp1d(np.log(Omega_data), np.log(Svals_clip), kind='linear', fill_value='extrapolate', assume_sorted=False)
    Sg = np.exp(f_interp(np.log(Omega_grid)))
    return np.maximum(Sg, 1e-30)

def estimate_tau_memory(Omega, Sg, S0, delta_t):
    y = np.maximum(Sg / S0, 1e-300)
    idx = np.where(y <= 0.5)[0]
    if idx.size == 0:
        return np.nan, np.nan
    i0 = int(idx[0])
    if i0 == 0:
        Om50 = Omega[i0]
    else:
        x1, x2 = Omega[i0 - 1], Omega[i0]
        y1, y2 = y[i0 - 1], y[i0]
        frac = (0.5 - y1) / max(y2 - y1, 1e-30)
        Om50 = float(x1 + frac * (x2 - x1))
    tau_est = 1.0 / max(Om50, 1e-30)
    theta = min(tau_est / max(delta_t, 1e-30), max(delta_t, 1e-30) / tau_est)
    return tau_est, theta

def s_short_memory_shape(omega, tau_m, S0=1.0, c_base=0.6, delta_t_ref=1.0):
    tm = max(tau_m, 0.0)
    x2 = (omega * tm) ** 2
    c0 = float(c_base) * (tm / float(delta_t_ref)) ** 2
    return float(S0) * (1.0 - c0 * (x2 / (1.0 + x2)))

def s_long_memory_shape(omega, tau_m, S0=1.0):
    tm = max(tau_m, 0.0)
    x2 = (omega * tm) ** 2
    return float(S0) / (1.0 + x2)

def chi_hat_dimless(w_dimless, mode='flat', strength=0.0, w0=1.0):
    w = np.asarray(w_dimless, dtype=float)
    if mode is None or mode == 'flat' or strength is None or abs(strength) <= 0.0 or w0 is None or not np.isfinite(w0) or w0 <= 0.0:
        return np.ones_like(w, dtype=float)
    if mode == 'gauss':
        return 1.0 + float(strength) * np.exp(- (w / float(w0)) ** 2)
    if mode == 'lorentz':
        return (1.0 + float(strength)) / (1.0 + (w / float(w0)) ** 2)
    return np.ones_like(w, dtype=float)

def compute_J_factors(omega, F_eff, chi_arr, omega_min, omega_max_op):
    mask = (omega >= omega_min) & (omega <= omega_max_op)
    if not np.any(mask):
        return np.nan, np.nan, np.nan
    om = omega[mask]
    if om.size < 2:
        return np.nan, np.nan, np.nan
    dln = np.log(om[1] / om[0])
    lnspan = log_span(omega_min, omega_max_op)
    J_F = ((1.0 / (2.0 * np.pi)) * np.sum((om * F_eff[mask]) * dln)) / max(lnspan, 1e-300)
    num = np.sum((om * F_eff[mask] * chi_arr[mask]) * dln)
    den = np.sum((om * F_eff[mask]) * dln)
    chi_avg = float(num / max(den, 1e-300))
    J_total = (1.0 / (2.0 * np.pi)) * (num / max(lnspan, 1e-300))
    return float(J_F), float(chi_avg), float(J_total)

def duhamel_time_kernel_norm_err_equiv(Delta, J_total):
    T_time = float(J_total * Delta)
    norm_err = 0.0
    return norm_err, T_time

def compute_metrics_for_dt_mode(Omega_data, PSD_data, delta_t, kappa, mode='SM', r_sm=0.2, r_lm=10.0, c_in=np.inf, use_theory_S=False):
    if Omega_data.size < 2:
        return None
    Omega_min_data = np.max([np.min(Omega_data[Omega_data > 0]), 1e-3])
    Omega_max_data = np.max(Omega_data)
    Omega_min_win = 1.0 / max(delta_t, 1e-30)
    Omega_min_used = max(Omega_min_data, Omega_min_win)
    Omega_up_mainlobe = (2.0 * np.pi - 1e-6) / max(delta_t, 1e-30)
    Omega_up_used = min(Omega_max_data, Omega_up_mainlobe)
    if Omega_up_used <= Omega_min_used * 1.001:
        return None
    Ngrid = 4096
    omega = np.exp(np.linspace(np.log(Omega_min_used), np.log(Omega_up_used), Ngrid))
    F_raw = filter_rectangular_double_sided(omega, delta_t)
    if use_theory_S:
        if mode == 'SM':
            tau_m = r_sm * delta_t
            Sg = s_short_memory_shape(omega, tau_m, S0=1.0, c_base=0.6, delta_t_ref=delta_t)
        else:
            tau_m = r_lm * delta_t
            Sg = s_long_memory_shape(omega, tau_m, S0=1.0)
        S_source = 'theory'
        tau_est = tau_m
    else:
        Sg = interpolate_loglog(Omega_data, PSD_data, omega)
        S_source = 'measured'
        S0 = max(Sg[0], 1e-300)
        tau_est, _ = estimate_tau_memory(omega, Sg, S0, delta_t)
    omH, Hfrac, _ = H_overlap_fraction(omega, F_raw, Sg, Omega_up_used)
    omW, Wfrac, _ = Wplus_fraction(omega, F_raw, Omega_up_used)
    omega_star = invert_quantile(omH, Hfrac, kappa)
    c_kappa_up = invert_quantile(omW, Wfrac, kappa)
    omega_up_cap = min(Omega_up_used, c_in) if np.isfinite(c_in) and c_in > 0 else Omega_up_used
    candidates = {'omega_star': omega_star, 'c_kappa_up': c_kappa_up, 'c_in': omega_up_cap, 'mainlobe': Omega_up_mainlobe}
    omega_max_op = min([v for v in candidates.values() if np.isfinite(v) and v > 0]) if any(np.isfinite(v) and v > 0 for v in candidates.values()) else omega_up_cap
    edge_active = None
    if np.isfinite(omega_max_op):
        for k, v in candidates.items():
            if np.isfinite(v) and abs(v - omega_max_op) <= 1e-12 * max(1.0, omega_max_op):
                edge_active = k
                break
    met = compute_band_metrics_from_arrays(omega, F_raw, Sg, Omega_min_used, omega_max_op)
    if met is None:
        return None
    Delta, lever, alpha, LSDelta, LFDelta, om_band, q_band, L_S, L_F, L_q = met
    gap = inequality_min_gap(omH, Hfrac, omW, Wfrac, trim_frac=0.20)
    theta_m = (tau_est / max(delta_t, 1e-30) if mode == 'SM' else max(delta_t, 1e-30) / tau_est) if (np.isfinite(tau_est) and tau_est > 0) else np.nan
    eps_edge = float(np.log(max(c_kappa_up / max(omega_star, 1e-30), 1.0)))
    F_eff, C_tilde = get_calibrated_F_for_band(omega, F_raw, Omega_min_used, omega_max_op)
    w_dim = omega * delta_t
    w_min = Omega_min_used * delta_t
    w_max = omega_max_op * delta_t
    w0_dim = (w_max - w_min) / 4.0 if (np.isfinite(w_max) and np.isfinite(w_min) and (w_max > w_min)) else 1.0
    chi_arr = chi_hat_dimless(w_dim, mode='flat', strength=0.0, w0=w0_dim)
    J_F, chi_avg, J_total = compute_J_factors(omega, F_eff, chi_arr, Omega_min_used, omega_max_op)
    norm_err_duhamel, T_time = duhamel_time_kernel_norm_err_equiv(Delta, J_total)
    CF = band_C_F(omega, F_raw, Omega_min_used, omega_max_op)
    S0_norm = max(Sg[0], 1e-300)
    q_band_full = (((omega * F_raw) / (2.0 * np.pi)) * (Sg / S0_norm)) / max(CF, 1e-300)
    mask_band = (omega >= Omega_min_used) & (omega <= omega_max_op)
    if np.sum(mask_band) >= 2:
        dln = np.log(omega[1] / omega[0])
        W_t_NM = float(np.sum(q_band_full[mask_band] * dln))
    else:
        W_t_NM = np.nan
    E_le_norm = -(W_t_NM - Delta) if np.isfinite(W_t_NM) else np.nan
    E_e_norm = -(Delta - log_span(Omega_min_used, c_kappa_up))
    return {
        'Omega': omega,
        'F_raw': F_raw,
        'F_eff': F_eff,
        'C_tilde': C_tilde,
        'Sg': Sg,
        'Omega_min': Omega_min_used,
        'Omega_up': Omega_up_used,
        'omega_star': omega_star,
        'c_kappa_up': c_kappa_up,
        'omega_max_op': omega_max_op,
        'edge_active': edge_active,
        'Delta': Delta,
        'lever': lever,
        'alpha': alpha,
        'gap': gap,
        'q_omega': om_band,
        'q_vals': q_band,
        'LSDelta': LSDelta,
        'LFDelta': LFDelta,
        'L_S': L_S,
        'L_F': L_F,
        'L_q': L_q,
        'tau_est': tau_est,
        'theta_m': theta_m,
        'eps_edge': eps_edge,
        'S_source': S_source,
        'chi_mode': 'flat',
        'chi_strength': 0.0,
        'chi_w0': w0_dim,
        'J_F': J_F,
        'chi_avg': chi_avg,
        'J_total': J_total,
        'duhamel_norm_err': norm_err_duhamel,
        'duhamel_T_time': T_time,
        'W_t_NM': W_t_NM,
        'E_le_norm': E_le_norm,
        'E_e_norm': E_e_norm,
        'c_in_used': c_in
    }

def memory_label_from_metrics(LSDelta, LFDelta, mode):
    if mode == 'SM':
        if np.isfinite(LSDelta) and LSDelta <= 0.10:
            return 'short'
        elif np.isfinite(LSDelta) and LSDelta >= 0.20:
            return 'borderline'
        else:
            return 'unknown'
    else:
        if np.isfinite(LFDelta) and LFDelta <= 0.10:
            return 'long'
        elif np.isfinite(LFDelta) and LFDelta >= 0.20:
            return 'borderline'
        else:
            return 'unknown'

def enforce_msis_on_result(res, mode='SM', eps0=0.10, alpha_tol=0.02, min_delta=5e-3):
    if res is None:
        return None
    Omega = res['Omega']; F_raw = res['F_raw']; Sg = res['Sg']
    Omega_min_used = res['Omega_min']
    upper0 = res['omega_max_op']
    fracs = np.linspace(1.0, 0.05, 401)
    best = None
    for f in fracs:
        upper = Omega_min_used * np.exp(np.log(upper0 / Omega_min_used) * f)
        met = compute_band_metrics_from_arrays(Omega, F_raw, Sg, Omega_min_used, upper)
        if met is None:
            continue
        Delta, lever, alpha, LSDelta, LFDelta, om_band, q_band, L_S, L_F, L_q = met
        if not (np.isfinite(Delta) and Delta >= min_delta):
            continue
        cons = LSDelta if mode == 'SM' else LFDelta
        pen = max(0.0, cons - eps0)
        cand = (max(abs(alpha - 1.0) - alpha_tol, 0.0), pen, -Delta, upper, Delta, lever, alpha, LSDelta, LFDelta, om_band, q_band, L_S, L_F, L_q)
        if (best is None) or (cand < best):
            best = cand
    if best is None:
        res['memory_label'] = memory_label_from_metrics(res.get('LSDelta', np.nan), res.get('LFDelta', np.nan), mode)
        return res
    _, _, _, upper_sel, Delta, lever, alpha, LSDelta, LFDelta, om_band, q_band, L_S, L_F, L_q = best
    F_eff, C_tilde = get_calibrated_F_for_band(Omega, F_raw, Omega_min_used, upper_sel)
    dt_here = res.get('delta_t', 1.0)
    chi_arr = chi_hat_dimless(Omega * dt_here, mode=res.get('chi_mode', 'flat'), strength=res.get('chi_strength', 0.0), w0=res.get('chi_w0', 1.0))
    J_F, chi_avg, J_total = compute_J_factors(Omega, F_eff, chi_arr, Omega_min_used, upper_sel)
    norm_err_duhamel, T_time = duhamel_time_kernel_norm_err_equiv(Delta, J_total)
    res2 = dict(res)
    res2['omega_max_op'] = upper_sel
    res2['Delta'] = Delta
    res2['lever'] = lever
    res2['alpha'] = alpha
    res2['LSDelta'] = LSDelta
    res2['LFDelta'] = LFDelta
    res2['q_omega'] = om_band
    res2['q_vals'] = q_band
    res2['L_S'] = L_S
    res2['L_F'] = L_F
    res2['L_q'] = L_q
    res2['err_bound'] = 0.5 * max(L_q, 0.0) * (Delta ** 2)
    res2['memory_label'] = memory_label_from_metrics(LSDelta, LFDelta, mode)
    res2['F_eff'] = F_eff
    res2['C_tilde'] = C_tilde
    res2['J_F'] = J_F
    res2['chi_avg'] = chi_avg
    res2['J_total'] = J_total
    res2['duhamel_norm_err'] = norm_err_duhamel
    res2['duhamel_T_time'] = T_time
    return res2

def optimize_dt_for_platform(Omega_data, PSD_data, dt_init, kappa, eps0=0.10, theta_short_max=0.30, r_sm=0.2, c_in=np.inf, use_theory_S=False):
    factors = np.geomspace(0.001, 1000.0, 2201)
    feas = []
    for f in factors:
        dt = float(dt_init * f)
        res = compute_metrics_for_dt_mode(Omega_data, PSD_data, dt, kappa, mode='SM', r_sm=r_sm, r_lm=10.0, c_in=c_in, use_theory_S=use_theory_S)
        if res is None:
            continue
        res['delta_t'] = dt
        res = enforce_msis_on_result(res, mode='SM', eps0=eps0, alpha_tol=0.02, min_delta=5e-3)
        if res is None:
            continue
        if not (np.isfinite(res['gap']) and res['gap'] >= 1e-6):
            continue
        if not (np.isfinite(res['LSDelta']) and res['LSDelta'] <= eps0):
            continue
        if not (np.isfinite(res['alpha']) and abs(res['alpha'] - 1.0) <= 0.02):
            continue
        tau_est = res.get('tau_est', np.nan)
        if not np.isfinite(tau_est) or tau_est <= 0:
            continue
        theta_short = float(tau_est / max(dt, 1e-30))
        if theta_short > theta_short_max:
            continue
        if res['Delta'] < 5e-3:
            continue
        feas.append((dt, res, theta_short))
    if feas:
        feas.sort(key=lambda x: (abs(x[1]['alpha'] - 1.0), x[1]['LSDelta'], x[2], -x[1]['Delta']))
        return feas[0][0], feas[0][1]
    res0 = compute_metrics_for_dt_mode(Omega_data, PSD_data, dt_init, kappa, mode='SM', r_sm=r_sm, r_lm=10.0, c_in=c_in, use_theory_S=use_theory_S)
    if res0 is not None:
        res0['delta_t'] = dt_init
        res0 = enforce_msis_on_result(res0, mode='SM', eps0=eps0, alpha_tol=0.02, min_delta=5e-3)
    return dt_init, res0

def optimize_dt_for_long_memory(Omega_data, PSD_data, dt_init, kappa, eps0=0.10, theta_long_max=0.30, r_lm=10.0, c_in=np.inf, use_theory_S=False):
    factors = np.geomspace(1e-3, 1.0, 2201)
    feas = []
    for f in factors:
        dt = float(dt_init * f)
        res = compute_metrics_for_dt_mode(Omega_data, PSD_data, dt, kappa, mode='LM', r_sm=0.2, r_lm=r_lm, c_in=c_in, use_theory_S=use_theory_S)
        if res is None:
            continue
        res['delta_t'] = dt
        res = enforce_msis_on_result(res, mode='LM', eps0=eps0, alpha_tol=0.02, min_delta=5e-3)
        if res is None:
            continue
        if not (np.isfinite(res['gap']) and res['gap'] >= 1e-6):
            continue
        if not (np.isfinite(res['LFDelta']) and res['LFDelta'] <= eps0):
            continue
        if not (np.isfinite(res['alpha']) and abs(res['alpha'] - 1.0) <= 0.02):
            continue
        tau_est = res.get('tau_est', np.nan)
        if not np.isfinite(tau_est) or tau_est <= 0:
            continue
        theta_long = float(dt / max(tau_est, 1e-30))
        if theta_long > theta_long_max:
            continue
        if res['Delta'] < 5e-3:
            continue
        feas.append((dt, res, theta_long))
    if feas:
        feas.sort(key=lambda x: (abs(x[1]['alpha'] - 1.0), x[1]['LFDelta'], x[2], -x[1]['Delta']))
        return feas[0][0], feas[0][1]
    res0 = compute_metrics_for_dt_mode(Omega_data, PSD_data, dt_init, kappa, mode='LM', r_sm=0.2, r_lm=r_lm, c_in=c_in, use_theory_S=use_theory_S)
    if res0 is not None:
        res0['delta_t'] = dt_init
        res0 = enforce_msis_on_result(res0, mode='LM', eps0=eps0, alpha_tol=0.02, min_delta=5e-3)
    return dt_init, res0

