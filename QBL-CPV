def pass_report(results, slope, R2, outdir, mode_suffix):
    ensure_dir(outdir)
    gap_thresh = 1e-6
    slope_lo, slope_hi = 0.9, 1.1
    R2_min = 0.98
    plat = []; gaps = []; pass_gap = []; alphas = []; alpha_pass = []
    for r in results:
        plat.append(r['tag'])
        gaps.append(r.get('gap', np.nan))
        pass_gap.append(int(np.isfinite(r.get('gap', np.nan)) and (r['gap'] >= gap_thresh)))
        a = r.get('alpha', np.nan)
        alphas.append(a)
        alpha_pass.append(int(np.isfinite(a) and (a >= slope_lo) and (a <= slope_hi)))
    pass_slope = int(np.isfinite(slope) and (slope >= slope_lo) and (slope <= slope_hi))
    pass_R2 = int(np.isfinite(R2) and (R2 >= R2_min))
    overall = int(all(pass_gap) and all(alpha_pass) and pass_slope and pass_R2)
    save_csv(os.path.join(outdir, f"cross_platform_PASS_{mode_suffix}.csv"),
             ['platform', 'ineq_min_gap', 'ineq_pass', 'alpha', 'alpha_pass', 'slope', 'R2', 'slope_pass', 'R2_pass', 'overall_pass',
              'gap_thresh', 'slope_lo', 'slope_hi', 'R2_min',
              'note'],
             [plat, gaps, pass_gap, alphas, alpha_pass, slope, R2, pass_slope, pass_R2, overall, gap_thresh, slope_lo, slope_hi, R2_min,
              'MSIS calibration enforced'])
    print(f"=== PASS REPORT ({mode_suffix}) ===")
    for p, g, pg, a, ap in zip(plat, gaps, pass_gap, alphas, alpha_pass):
        try:
            print(f"[{p}] gap={g:.3e}, gap_pass={bool(pg)}, alpha={a:.4f}, alpha_pass={bool(ap)}")
        except Exception:
            print(f"[{p}] gap={g}, gap_pass={bool(pg)}, alpha={a}, alpha_pass={bool(ap)}")
    print(f"collapse slope={slope:.4f}, R2={R2:.4f}, slope_pass={bool(pass_slope)}, R2_pass={bool(pass_R2)}")
    print(f"OVERALL PASS = {bool(overall)}")
    return overall

