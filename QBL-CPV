def stability_msis_analysis(results, outdir, mode_suffix, specs, kappa_base, synthetic_params):
    ensure_dir(outdir)
    tags = [r['tag'] for r in results]
    dt_map = {r['tag']: r.get('delta_t', np.nan) for r in results}
    dt_factors = [0.9, 1.0, 1.1]
    kappa_vals = [0.75, 0.8, 0.85]
    tilt_eps = [-0.05, 0.0, 0.05]
    rows = []
    for t in tags:
        Omega_data, S_data = get_Omega_S_for_tag(t, specs, synthetic_params)
        if Omega_data is None or S_data is None:
            rows.append([t, np.nan, np.nan, np.nan, np.nan, np.nan, np.nan, 0, 0, 0.0])
            continue
        dt0 = dt_map.get(t, np.nan)
        if not np.isfinite(dt0):
            rows.append([t, np.nan, np.nan, np.nan, np.nan, np.nan, np.nan, 0, 0, 0.0])
            continue
        alphas = []; deltas = []; levers = []; passes = 0; total = 0
        for df in dt_factors:
            for kv in kappa_vals:
                for eps in tilt_eps:
                    Om_ref = np.exp(np.mean(np.log(Omega_data)))
                    S_mod = S_data * (Omega_data / Om_ref) ** eps
                    res = compute_metrics_for_dt_mode(Omega_data, S_mod, dt0 * df, kv, mode=('SM' if mode_suffix == 'SM' else 'LM'), use_theory_S=False)
                    if res is None:
                        continue
                    res = enforce_msis_on_result(res, mode=('SM' if mode_suffix == 'SM' else 'LM'), eps0=0.10, alpha_tol=0.02, min_delta=5e-3)
                    if res is None:
                        continue
                    total += 1
                    if np.isfinite(res.get('gap', np.nan)) and res['gap'] >= 1e-6 and np.isfinite(res.get('alpha', np.nan)) and abs(res['alpha'] - 1.0) <= 0.02:
                        passes += 1
                    if np.isfinite(res.get('alpha', np.nan)) and np.isfinite(res.get('Delta', np.nan)) and np.isfinite(res.get('lever', np.nan)):
                        alphas.append(res['alpha']); deltas.append(res['Delta']); levers.append(res['lever'])
        if len(alphas) == 0:
            rows.append([t, np.nan, np.nan, np.nan, np.nan, np.nan, np.nan, passes, total, float(passes / max(total, 1))])
            continue
        rows.append([t, float(np.mean(alphas)), float(np.std(alphas)), float(np.mean(deltas)), float(np.std(deltas)), float(np.mean(levers)), float(np.std(levers)), passes, total, float(passes / max(total, 1))])
    save_csv(os.path.join(outdir, f"stability_msis_{mode_suffix}.csv"),
             ['platform', 'alpha_mean', 'alpha_std', 'Delta_mean', 'Delta_std', 'lever_mean', 'lever_std', 'pass_count', 'total_count', 'pass_rate'],
             list(map(list, zip(*rows))) if rows else [[], [], [], [], [], [], [], [], [], []])
    return rows

def jitter_msis_analysis(results, outdir, mode_suffix, specs, synthetic_params, nreal=64, sigma_log=0.05, seed=1234):
    ensure_dir(outdir)
    rng = np.random.default_rng(seed)
    tags = [r['tag'] for r in results]
    dt_map = {r['tag']: r.get('delta_t', np.nan) for r in results}
    kappa_vals = [0.8]
    rows = []
    for t in tags:
        Omega_data, S_data = get_Omega_S_for_tag(t, specs, synthetic_params)
        dt0 = dt_map.get(t, np.nan)
        if Omega_data is None or S_data is None or not np.isfinite(dt0):
            rows.append([t, np.nan, np.nan, np.nan, np.nan, 0.0])
            continue
        alpha_list = []; delta_list = []; lever_list = []; pass_count = 0
        for r in range(nreal):
            noise = rng.normal(0.0, sigma_log, size=Omega_data.shape)
            S_mod = S_data * np.exp(noise)
            res = compute_metrics_for_dt_mode(Omega_data, S_mod, dt0, kappa_vals[0], mode=('SM' if mode_suffix == 'SM' else 'LM'), use_theory_S=False)
            if res is None:
                continue
            res = enforce_msis_on_result(res, mode=('SM' if mode_suffix == 'SM' else 'LM'), eps0=0.10, alpha_tol=0.02, min_delta=5e-3)
            if res is None:
                continue
            if np.isfinite(res.get('gap', np.nan)) and res['gap'] >= 1e-6 and np.isfinite(res.get('alpha', np.nan)) and abs(res['alpha'] - 1.0) <= 0.02:
                pass_count += 1
            if np.isfinite(res.get('alpha', np.nan)) and np.isfinite(res.get('Delta', np.nan)) and np.isfinite(res.get('lever', np.nan)):
                alpha_list.append(res['alpha']); delta_list.append(res['Delta']); lever_list.append(res['lever'])
        if len(alpha_list) == 0:
            rows.append([t, np.nan, np.nan, np.nan, np.nan, 0.0])
            continue
        rows.append([t, float(np.mean(alpha_list)), float(np.std(alpha_list)), float(np.mean(delta_list)), float(np.std(delta_list)), float(pass_count / max(nreal, 1))])
    save_csv(os.path.join(outdir, f"jitter_msis_{mode_suffix}.csv"),
             ['platform', 'alpha_mean', 'alpha_std', 'Delta_mean', 'Delta_std', 'pass_rate'],
             list(map(list, zip(*rows))) if rows else [[], [], [], [], [], []])
    return rows

