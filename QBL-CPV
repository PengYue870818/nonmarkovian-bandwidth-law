def prepare_platform_from_csv_SM(path, fx_name, fy_name, delta_t_init, outdir, tag, kappa=0.8, r_sm=0.2, c_in=np.inf, use_theory_S=False):
    f_Hz, Svals = read_two_column_csv(path, fx_name, fy_name)
    f_Hz, Svals = dedup_average_by_freq(f_Hz, Svals)
    if f_Hz.size < 2:
        raise RuntimeError(f"[{tag}] Not enough valid PSD points.")
    Omega_data = 2.0 * np.pi * f_Hz
    dt_opt, res = optimize_dt_for_platform(Omega_data, Svals, delta_t_init, kappa, eps0=0.10, theta_short_max=0.30, r_sm=r_sm, c_in=c_in, use_theory_S=use_theory_S)
    if res is None:
        raise RuntimeError(f"[{tag}] Optimization failed.")
    res['delta_t'] = dt_opt
    return per_platform_outputs(tag, res, outdir, "SM")

