def cross_platform_collapse(results, outdir, mode_suffix):
    ensure_dir(outdir)
    xs = []; ys = []; labs = []; cols = []; errs = []; alphas = []; alpha_errs = []; lq_vals = []
    for r in results:
        if (r is None) or (not np.isfinite(r.get('Delta', np.nan))) or (r['Delta'] <= 0):
            continue
        xs.append(r['Delta']); ys.append(r['lever']); labs.append(r['tag'])
        L_q = r.get('L_q', np.nan)
        lq_vals.append(L_q)
        err_like = 0.5 * max(L_q if np.isfinite(L_q) else 0.0, 0.0) * (r['Delta'] ** 2)
        errs.append(err_like)
        a = r.get('alpha', np.nan); alphas.append(a)
        alpha_errs.append((err_like / max(r['Delta'], 1e-30)) if (np.isfinite(err_like) and r['Delta'] > 0) else np.nan)
    color_map = {
        'FluxQubit_Bylander2011': '#1f77b4',
        'NV_Diamond_Romach2015_NV3': '#2ca02c',
        'SiGe_QD_Connors2020': '#ff7f0e',
        'GaAs_ST0_Dial2013': '#d62728'
    }
    for lab in labs:
        cols.append(color_map.get(lab, '#9467bd'))
    fig = plt.figure(figsize=(7.4, 5.2))
    if len(xs) == 0:
        xs = [np.nan]; ys = [np.nan]; labs = ['NA']; cols = ['#1f77b4']; errs = [np.nan]; alphas = [np.nan]; alpha_errs = [np.nan]; lq_vals = [np.nan]
    xs_arr = np.array(xs, dtype=float); ys_arr = np.array(ys, dtype=float)
    xmax = (float(np.nanmax(xs_arr)) * 1.25 if np.any(np.isfinite(xs_arr)) else 1.0)
    xline = np.linspace(0.0, xmax, 500)
    plt.plot(xline, xline, color='k', ls='--', lw=1.8, label='K-line (ideal): y = x', zorder=2)
    order = np.argsort(xs_arr)
    for idx in order:
        x, y, lab, c, e = xs_arr[idx], ys_arr[idx], labs[idx], cols[idx], errs[idx]
        if np.isfinite(e):
            plt.errorbar([x], [y], yerr=[[e], [e]], fmt='o', ms=8, color=c, ecolor=c, elinewidth=1.8, capsize=4, markeredgecolor='k', markeredgewidth=0.9, label=lab, zorder=5)
        else:
            plt.scatter([x], [y], s=90, c=c, edgecolors='k', linewidths=0.9, label=lab, zorder=5)
        try:
            plt.text(x * 1.04, y * 1.04, lab, fontsize=9, color=c, zorder=6)
        except Exception:
            pass
    mask = np.isfinite(xs_arr) & np.isfinite(ys_arr) & (xs_arr > 0)
    if np.sum(mask) >= 2:
        Sxx = float(np.sum(xs_arr[mask] ** 2))
        Sxy = float(np.sum(xs_arr[mask] * ys_arr[mask]))
        slope = Sxy / max(Sxx, 1e-30)
        yhat = slope * xs_arr[mask]
        SSE = float(np.sum((ys_arr[mask] - yhat) ** 2))
        SST0 = float(np.sum((ys_arr[mask]) ** 2))
        R2 = 1.0 - SSE / max(SST0, 1e-30)
        dof = max(int(np.sum(mask)) - 1, 1)
        sigma2 = SSE / max(dof, 1)
        se_slope = float(np.sqrt(sigma2 / max(Sxx, 1e-30)))
        tval = float(t.ppf(0.975, dof))
        band_up = (slope + tval * se_slope) * xline
        band_lo = (slope - tval * se_slope) * xline
        plt.plot(xline, slope * xline, 'r-', lw=2.0, label=f'K-fit (global): y={slope:.4f}x', zorder=3)
        plt.fill_between(xline, band_lo, band_up, color='r', alpha=0.28, label='95% CI (global fit)', zorder=1)
        plt.plot(xline, band_lo, color='r', lw=1.2, alpha=0.9, zorder=2)
        plt.plot(xline, band_up, color='r', lw=1.2, alpha=0.9, zorder=2)
    else:
        slope = np.nan; R2 = np.nan; se_slope = np.nan
    for lab, c, a, ae in zip(labs, cols, alphas, alpha_errs):
        if np.isfinite(a):
            y_pl = a * xline
            plt.plot(xline, y_pl, color=c, lw=1.6, alpha=0.9, label=f'K-line [{lab}]: y={a:.4f}x', zorder=2)
            if np.isfinite(ae) and ae > 0:
                y_lo = (a - ae) * xline
                y_hi = (a + ae) * xline
                plt.fill_between(xline, y_lo, y_hi, color=c, alpha=0.10, zorder=1)
                plt.plot(xline, y_lo, color=c, lw=0.8, alpha=0.7, zorder=1)
                plt.plot(xline, y_hi, color=c, lw=0.8, alpha=0.7, zorder=1)
    plt.xlabel('Delta = ln(omega_max_op / omega_min)')
    plt.ylabel('Lever = ∫ q(ω) d ln ω')
    plt.title(f'Cross-platform single-window collapse ({mode_suffix})')
    handles, labels = plt.gca().get_legend_handles_labels()
    if labels:
        bylab = {}
        for h, l in zip(handles, labels):
            if l not in bylab:
                bylab[l] = h
        plt.legend(bylab.values(), bylab.keys(), frameon=False, fontsize=8, loc='upper left', ncol=1)
    plt.tight_layout()
    fig_path = os.path.join(outdir, f"cross_platform_collapse_{mode_suffix}.png")
    plt.savefig(fig_path, dpi=220, bbox_inches='tight')
    plt.close()
    save_csv(os.path.join(outdir, f"cross_platform_collapse_{mode_suffix}.csv"),
             ['platform', 'Delta', 'lever', 'alpha', 'alpha_err', 'Lq', 'err_bar', 'diff(lever-Delta)', 'slope_fit', 'slope_se', 'R2', 'figure'],
             [labs, xs_arr, ys_arr, alphas, alpha_errs, lq_vals,
              [0.5 * max((lq_vals[i] if i < len(lq_vals) and np.isfinite(lq_vals[i]) else 0.0), 0.0) * (xs_arr[i] ** 2) if np.isfinite(xs_arr[i]) else np.nan for i in range(len(xs_arr))],
              (ys_arr - xs_arr) if np.all(np.isfinite(xs_arr)) else [], slope, se_slope, R2, fig_path])
    return slope, R2

