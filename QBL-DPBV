def eta_prediction_vs_fit(cfg, tag, omega, F_raw, omega_min, omega_up, tau_list, a_lin=0.3):
    omW, Wfrac, _ = Wplus_fraction(omega, F_raw, omega_up)
    Omega0 = invert_quantile(omW, Wfrac, cfg.kappa_coverage)
    xs = []; ys = []
    for tm in tau_list:
        S_lin = lambda om, tt: S_short_memory_linear(om, tt, S0=1.0, a_base=a_lin, delta_t_ref=cfg.delta_t)
        S = S_lin(omega, tm)
        S = np.maximum(1e-12, S)
        omH, frac, _ = H_overlap_fraction(omega, F_raw, S, omega_up)
        omega_star = invert_quantile(omH, frac, cfg.kappa_coverage)
        xs.append((tm / cfg.delta_t) ** 2); ys.append(Omega0 - omega_star)
    eta_fit, _, _, _, _ = _quad_fit_through_origin(xs, ys)
    I0_up = float(integrate.trapezoid(F_raw[(omega <= omega_up)], x=omega[(omega <= omega_up)]))
    I2_up = float(integrate.trapezoid((omega[(omega <= omega_up)] ** 2) * F_raw[(omega <= omega_up)], x=omega[(omega <= omega_up)]))
    mask0 = omega <= Omega0
    I0_0 = float(integrate.trapezoid(F_raw[mask0], x=omega[mask0]))
    I2_0 = float(integrate.trapezoid((omega[mask0] ** 2) * F_raw[mask0], x=omega[mask0]))
    r_up = I2_up / max(I0_up, 1e-300); r_0 = I2_0 / max(I0_0, 1e-300)
    dOmega = 1e-3 * Omega0
    def Psi(Omg, tau):
        S = S_short_memory_linear(omega, tau, 1.0, a_lin, cfg.delta_t)
        S = np.maximum(1e-12, S)
        omH, frac, _ = H_overlap_fraction(omega, F_raw, S, omega_up)
        return float(np.interp(Omg, omH, frac, left=0.0, right=1.0) - cfg.kappa_coverage)
    dt = 1e-3 * cfg.delta_t
    d2Psi = (Psi(Omega0, 2*dt) - 2*Psi(Omega0, dt) + Psi(Omega0, 0.0)) / max(dt*dt, 1e-30)
    dPsi_dO = (Psi(Omega0 + dOmega, 0.0) - Psi(Omega0 - dOmega, 0.0)) / max(2*dOmega, 1e-30)
    eta_pred = d2Psi / max(2*dPsi_dO, 1e-300)
    fig = plt.figure(figsize=(6.8,4.2))
    plt.bar([0,1],[eta_fit, eta_pred], color=['#4C78A8','#E45756'])
    plt.xticks([0,1],['eta_fit','eta_pred'])
    plt.title('eta fit vs pred (linear short memory)')
    plt.tight_layout()
    queue_fig(fig, fig_prefix(cfg.outdir, f"{tag}.png"))
    save_csv(fig_prefix(cfg.outdir, f"{tag}.csv"),
             ['Omega0','I0_up','I2_up','I0_0','I2_0','r_up','r_0','d2Psi','dPsi_dO','eta_fit','eta_pred'],
             [Omega0, I0_up, I2_up, I0_0, I2_0, r_up, r_0, d2Psi, dPsi_dO, eta_fit, eta_pred])


