def _quad_fit_through_origin(xs, ys):
    xs = np.asarray(xs, dtype=float); ys = np.asarray(ys, dtype=float)
    mask = np.isfinite(xs) & np.isfinite(ys)
    x = xs[mask]; y = ys[mask]
    if x.size < 3 or np.allclose(x, 0):
        return np.nan, np.nan, (np.nan, np.nan), np.nan, y * 0
    Sxx = np.sum(x * x); Sxy = np.sum(x * y)
    eta = Sxy / max(Sxx, 1e-30)
    yhat = eta * x
    resid = y - yhat
    dof = max(x.size - 1, 1)
    sigma2 = np.sum(resid * resid) / dof
    var_eta = sigma2 / max(Sxx, 1e-30)
    se = np.sqrt(var_eta)
    tval = stats.t.ppf(0.975, dof)
    ci95 = (eta - tval * se, eta + tval * se)
    ss_tot = np.sum((y - np.mean(y)) ** 2) + 1e-30
    r2 = 1.0 - np.sum(resid * resid) / ss_tot
    return float(eta), float(se), (float(ci95[0]), float(ci95[1])), float(r2), resid


