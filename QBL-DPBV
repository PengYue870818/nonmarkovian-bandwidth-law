        omH, Hfrac, _ = H_overlap_fraction(omega, F_raw, S, omega_up)
        omW, Wfrac, _ = Wplus_fraction(omega, F_raw, omega_up)
        omega_star = invert_quantile(omH, Hfrac, cfg.kappa_coverage)
