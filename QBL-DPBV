def _F_rect_dimless(w):
    w = np.asarray(w, dtype=float)
    w2 = np.maximum(w, 1e-300)
    return 4.0 * (np.sin(0.5 * w) ** 2) / (w2 ** 2)

def _chi_hat_from_params(w, mode, strength, w0):
    w = np.asarray(w, dtype=float)
    if (mode is None) or (mode == "flat") or (strength is None) or (abs(strength) <= 0.0) or (w0 is None) or (not np.isfinite(w0)) or (w0 <= 0.0):
        return np.ones_like(w, dtype=float)
    if mode == "gauss":
        return 1.0 + float(strength) * np.exp(- (w / float(w0)) ** 2)
    if mode == "lorentz":
        return (1.0 + float(strength)) / (1.0 + (w / float(w0)) ** 2)
    return np.ones_like(w)

def _chi_hat_self_energy_dimless(chi0, S_shape, sigma_se):
    chi0 = np.asarray(chi0, dtype=float)
    S_shape = np.asarray(S_shape, dtype=float)
    if sigma_se is None or sigma_se == 0.0:
        return chi0
    denom = 1.0 - sigma_se * (S_shape - 1.0) * chi0
    denom = np.where(np.abs(denom) < 1e-12, np.sign(denom) * 1e-12, denom)
    return chi0 / denom

def _multi_window_gain_dimless(w, n_windows=1, duty=1.0):
    if n_windows <= 1 or duty <= 0:
        return np.ones_like(w, dtype=float)
    x = 0.5 * np.asarray(w, dtype=float) / max(duty, 1e-9)
    num = np.sin(n_windows * x)
    den = np.sin(x)
    den = np.where(np.abs(den) < 1e-12, 1e-12, den)
    g = (num / den) ** 2
    return np.maximum(g, 0.0)

def _band_limits_paperA(cfg: TheoryConfig, base_geom):
    v_eff = max(abs(cfg.v_loc) if cfg.v_eff_mode == "loc" else np.sqrt(K_B * cfg.T / max(cfg.m, 1e-300)), 1e-30)
    omega_min = max(1.0 / max(cfg.delta_t, 1e-30), v_eff / max(cfg.L_v, 1e-30))
    sigma_G_phys_max = base_geom['sigma_G_phys_max']
    mainlobe_cap = base_geom['mainlobe_cap']
    omega_geom_up = v_eff / max(sigma_G_phys_max, 1e-30)
    omega_up = min(c for c in [cfg.omega_sys, cfg.c_kappa / max(cfg.delta_t, 1e-30), omega_geom_up, mainlobe_cap] if np.isfinite(c) and c > 0)
    return float(omega_min), float(omega_up)

def _operational_edge_paperA(cfg, omega, F, S_arr, omega_min, omega_up):
    omH, fracH, _ = H_overlap_fraction(omega, F, S_arr, omega_up)
    omega_star = invert_quantile(omH, fracH, cfg.kappa_coverage)
    omW, fracW, _ = Wplus_fraction(omega, F, omega_up)
    c_kappa_up = invert_quantile(omW, fracW, cfg.kappa_coverage)
    omega_max_op = min(omega_star, c_kappa_up, omega_up)
    return float(omega_star), float(c_kappa_up), float(omega_max_op)

def _interp1_with_fill(x_new, x, y):
    x = np.asarray(x).ravel()
    y = np.asarray(y).ravel()
    x_new = np.asarray(x_new)
    mask = np.isfinite(x) & np.isfinite(y)
    if mask.sum() == 0:
        return np.full_like(x_new, np.nan, dtype=y.dtype)
    x = x[mask]
    y = y[mask]
    idx = np.argsort(x)
    x = x[idx]
    y = y[idx]
    if x.size == 1:
        return np.full_like(x_new, y[0], dtype=y.dtype)
    if np.iscomplexobj(y):
        yr = np.interp(x_new, x, y.real, left=y.real[0], right=y.real[-1])
        yi = np.interp(x_new, x, y.imag, left=y.imag[0], right=y.imag[-1])
        return yr + 1j * yi
    else:
        return np.interp(x_new, x, y, left=y[0], right=y[-1])

def run_time_domain_duhamel_strict(cfg: TheoryConfig,
                                   tau_list=None,
                                   mem_kind='short',
                                   chi_mode=None,
                                   chi_strength=None,
                                   chi_w0_factor=4.0,
                                   n_om=32768,
                                   Nt_tau=4097,
                                   use_self_energy=False,
                                   sigma_se=0.0,
                                   multi_window=None):
    base = build_geometry_and_band(cfg)
    omega_min, omega_up = _band_limits_paperA(cfg, base)
    omega_u = np.linspace(0.0, omega_up, int(max(2048, n_om)))
    omega_log = nm_freq_grid(omega_min, omega_up, cfg.nm_n_omega)
    w_u = omega_u * cfg.delta_t
    w_log = omega_log * cfg.delta_t
    F_dim = _F_rect_dimless(w_log)
    if multi_window is not None:
        nW = int(multi_window.get('n', 1))
        duty = float(multi_window.get('duty', 1.0))
        F_dim = F_dim * _multi_window_gain_dimless(w_log, n_windows=nW, duty=duty)
    if tau_list is None:
        if mem_kind == 'short':
            tau_list = cfg.nm_short_tau_list or list(np.linspace(0.05, 0.8, 16) * cfg.delta_t)
        else:
            tau_list = cfg.nm_long_tau_list or list(np.linspace(4.0, 40.0, 16) * cfg.delta_t)
    rows = {'tau_m_s': [], 'delta_p1_time_ind': [], 'delta_p1_main': [], 'norm_err': [],
            'ln_band': [], 'L_qDelta': [], 'E_le': [], 'E_e': [], 'omega_star': [],
            'c_kappa_up': [], 'omega_max_op': []}
    tk_rows = {'tau_m_s': [], 'tau': [], 'chi_tau': [], 'tri': []}
    for tau_m in tau_list:
        if mem_kind == 'short':
            S_arr_log = S_short_memory(omega_log, tau_m, S0=1.0, c_base=0.6, delta_t_ref=cfg.delta_t)
            S_arr_u = S_short_memory(omega_u, tau_m, S0=1.0, c_base=0.6, delta_t_ref=cfg.delta_t)
        else:
            S_arr_log = S_long_memory(omega_log, tau_m, S0=1.0)
            S_arr_u = S_long_memory(omega_u, tau_m, S0=1.0)
        S0_log = float(max(S_arr_log[0], 1e-30))
        omega_star, c_kappa_up, omega_max_op = _operational_edge_paperA(cfg, omega_log, F_dim, S_arr_log, omega_min, omega_up)
        ln_band = _log_span(omega_min, omega_max_op)
        mask_log = (omega_log >= omega_min) & (omega_log <= omega_max_op)
        wB = w_log[mask_log]
        w_min = omega_min * cfg.delta_t
        w_max_op = omega_max_op * cfg.delta_t
        w0_dim = max((w_max_op - w_min) / max(chi_w0_factor, 1.0), 1e-9)
        if (chi_mode is None) and (chi_strength is None):
            chi0_u = chi_hat_dimless(cfg, w_u)
        else:
            chi0_u = _chi_hat_from_params(w_u, chi_mode or "flat", chi_strength if chi_strength is not None else 0.0, w0_dim)
        chi0_B = _interp1_with_fill(wB, w_u, chi0_u)
        S_shape_u = np.maximum(S_arr_u, 1e-300) / max(S_arr_u[0], 1e-30)
        chi_u_se = _chi_hat_self_energy_dimless(chi0_u, S_shape_u, sigma_se) if use_self_energy else chi0_u
        chi_B = _interp1_with_fill(wB, w_u, chi_u_se)
        if multi_window is not None:
            nW = int(multi_window.get('n', 1))
            duty = float(multi_window.get('duty', 1.0))
            Gdim = _multi_window_gain_dimless(wB, n_windows=nW, duty=duty)
        else:
            Gdim = 1.0
        tau = np.linspace(0.0, 1.0, int(max(3, Nt_tau)))
        chi_tau = np.zeros_like(tau, dtype=float)
        if wB.size >= 2:
            for it, tv in enumerate(tau):
                chi_tau[it] = (1.0 / np.pi) * float(integrate.trapezoid((chi_B * Gdim) * np.cos(wB * tv), x=wB))
        tri = (1.0 - tau)
        T_time = float(integrate.trapezoid(tri * chi_tau, x=tau))
        p_th = base['p_th']; epsilon = base['epsilon']; K_val = base['K']
        delta_p1_time_ind = - p_th * (epsilon ** 2) * K_val * T_time
        if wB.size >= 2:
            dlnw = np.log(wB[1] / wB[0])
            F_band = F_dim[mask_log]
            num = np.sum((wB * F_band * chi_B * Gdim) * dlnw)
            J = float((1.0 / (2.0 * np.pi)) * (num / max(ln_band, 1e-300)))
        else:
            J = 1.0
        delta_p1_main = - p_th * (epsilon ** 2) * K_val * J * ln_band
        C_F = band_C_F(omega_log, _F_rect_dimless(w_log), omega_min, omega_max_op)
        q_B = ((_F_rect_dimless(w_log) / (2.0 * np.pi)) * (np.maximum(S_arr_log, 1e-300) / max(S0_log, 1e-30))) / max(C_F, 1e-300)
        if wB.size >= 2:
            dlnom = np.log(omega_log[mask_log][1] / omega_log[mask_log][0])
            W_t_NM = float(np.sum(q_B[mask_log] * dlnom))
        else:
            W_t_NM = 0.0
        E_le = - p_th * (epsilon ** 2) * K_val * (W_t_NM - ln_band)
        E_e = - p_th * (epsilon ** 2) * K_val * (ln_band - _log_span(omega_min, c_kappa_up))
        rows['tau_m_s'].append(tau_m)
        rows['delta_p1_time_ind'].append(delta_p1_time_ind)
        rows['delta_p1_main'].append(delta_p1_main)
        rows['norm_err'].append(abs(delta_p1_time_ind - delta_p1_main) / max(p_th * (epsilon ** 2) * abs(K_val), 1e-30))
        rows['ln_band'].append(ln_band)
        rows['L_qDelta'].append(log_lipschitz(omega_log, q_B, omega_min, omega_max_op) * ln_band)
        rows['E_le'].append(E_le)
        rows['E_e'].append(E_e)
        rows['omega_star'].append(omega_star)
        rows['c_kappa_up'].append(c_kappa_up)
        rows['omega_max_op'].append(omega_max_op)
        tk_rows['tau_m_s'] += [tau_m] * len(tau)
        tk_rows['tau'] += list(tau)
        tk_rows['chi_tau'] += list(chi_tau)
        tk_rows['tri'] += list(tri)
    tag = f"A_time_duhamel_{mem_kind}" + ("_se" if use_self_energy else "") + ("_mw" if multi_window else "")
    save_csv(fig_prefix(cfg.outdir, f"{tag}.csv"),
             ['tau_m_s','delta_p1_time_ind','delta_p1_main','norm_err','ln_band','L_qDelta','E_le','E_e','omega_star','c_kappa_up','omega_max_op'],
             [rows['tau_m_s'], rows['delta_p1_time_ind'], rows['delta_p1_main'], rows['norm_err'], rows['ln_band'], rows['L_qDelta'], rows['E_le'], rows['E_e'], rows['omega_star'], rows['c_kappa_up'], rows['omega_max_op']])
    save_csv(fig_prefix(cfg.outdir, f"{tag}_kernel.csv"),
             ['tau_m_s','tau','chi_tau','triangle_weight'],
             [tk_rows['tau_m_s'], tk_rows['tau'], tk_rows['chi_tau'], tk_rows['tri']])
    try:
        fig, ax = plt.subplots(1,3, figsize=(15,4.2))
        plt.sca(ax[0]); plt.plot(rows['tau_m_s'], rows['delta_p1_time_ind'], 'o-', label='time-duhamel'); plt.plot(rows['tau_m_s'], rows['delta_p1_main'], 's-', label='J*ln'); plt.xlabel('tau_m'); plt.ylabel('delta_p1'); plt.title('time vs main'); plt.legend(frameon=False)
        plt.sca(ax[1]); xa = np.array(rows['L_qDelta'], dtype=float); ya = np.array(rows['norm_err'], dtype=float); msk = (xa > 0) & (ya > 0) & np.isfinite(xa) & np.isfinite(ya)
        if np.any(msk):
            xs = np.log(xa[msk]); ys = np.log(ya[msk]); plt.scatter(xs, ys, s=22); A = np.vstack([np.ones(xs.size), xs]).T; coef, _, _, _ = np.linalg.lstsq(A, ys, rcond=None); xr = np.linspace(xs.min(), xs.max(), 256); plt.plot(xr, coef[0] + coef[1]*xr, 'k--', label=f'b~{coef[1]:.2f}'); plt.legend(frameon=False)
        plt.xlabel('log(L_qDelta)'); plt.ylabel('log(norm_err)'); plt.title('order fit')
        plt.sca(ax[2]); samp = min(3, len(np.unique(tk_rows['tau_m_s'])))
        if samp > 0:
            ts = np.array(tk_rows['tau']); ch = np.array(tk_rows['chi_tau']); tri = np.array(tk_rows['tri']); tau_arr = np.array(tk_rows['tau_m_s']); uniq = []
            for tm in rows['tau_m_s']:
                if tm not in uniq:
                    uniq.append(tm)
                if len(uniq) >= samp:
                    break
            for tm in uniq:
                m = (tau_arr == tm); plt.plot(ts[m], ch[m], '-', label=f'chi(tau), tau={tm:.2e}'); plt.plot(ts[m], tri[m] * (np.max(ch[m]) if np.any(m) else 1.0), ':', alpha=0.6)
            plt.xlabel('tau'); plt.ylabel('chi(tau)'); plt.title('kernel'); plt.legend(frameon=False)
        plt.tight_layout(); queue_fig(fig, fig_prefix(cfg.outdir, f"{tag}.png"))
    except Exception:
        pass

def build_failure_phase_diagram_extended(cfg: TheoryConfig,
                                         strength_list=None,
                                         w0_factor_list=None,
                                         window_ripple=0.0,
                                         mem_probe=(0.4, 15.0),
                                         k_bias_thresh=0.1,
                                         use_self_energy=False,
                                         sigma_se=0.0,
                                         multi_window=None):
    base = build_geometry_and_band(cfg)
    omega_min, omega_up = _band_limits_paperA(cfg, base)
    omega = nm_freq_grid(omega_min, omega_up, cfg.nm_n_omega)
    w = omega * cfg.delta_t
    F_dim = _F_rect_dimless(w)
    amp = 0.0
    if isinstance(window_ripple, (list, tuple, np.ndarray)):
        if len(window_ripple) > 0:
            amp = float(window_ripple[0])
    else:
        amp = float(window_ripple)
    if amp != 0.0:
        F_dim = F_dim * (1.0 + amp * np.cos(4.0 * np.log(np.maximum(w, 1e-30))))
    if multi_window is not None:
        nW = int(multi_window.get('n', 1))
        duty = float(multi_window.get('duty', 1.0))
        F_dim = F_dim * _multi_window_gain_dimless(w, n_windows=nW, duty=duty)
    if strength_list is None:
        strength_list = np.linspace(0.0, 0.6, 19)
    if w0_factor_list is None:
        w0_factor_list = np.geomspace(0.5, 8.0, 17)
    grid_bias = np.zeros((len(strength_list), len(w0_factor_list)))
    grid_LqD  = np.zeros_like(grid_bias)
    grid_ck   = np.zeros_like(grid_bias)
    for i, a in enumerate(strength_list):
        for j, f0 in enumerate(w0_factor_list):
            def one_tau(tau_m):
                S_arr = S_short_memory(omega, tau_m, 1.0, 0.6, cfg.delta_t) if (tau_m <= cfg.delta_t) else S_long_memory(omega, tau_m, 1.0)
                S0 = float(max(S_arr[0], 1e-30))
                omega_star, c_kappa_up, omega_max_op = _operational_edge_paperA(cfg, omega, F_dim, S_arr, omega_min, omega_up)
                lnspan = _log_span(omega_min, omega_max_op)
                mask = (omega >= omega_min) & (omega <= omega_max_op)
                if np.count_nonzero(mask) < 2:
                    return np.nan, 0.0, 0.0
                dln = np.log(omega[mask][1] / omega[mask][0])
                w_min = omega_min * cfg.delta_t
                w_max_op = omega_max_op * cfg.delta_t
                w0_dim = max((w_max_op - w_min) / max(f0, 1.0), 1e-9)
                chi0 = _chi_hat_from_params(w, "gauss", a, w0_dim)
                S_shape = np.maximum(S_arr, 1e-300) / max(S_arr[0], 1e-30)
                chi_arr = _chi_hat_self_energy_dimless(chi0, S_shape, sigma_se) if use_self_energy else chi0
                C_tilde = float(((1.0 / (2.0 * np.pi)) * np.sum((F_dim[mask] * chi_arr[mask]) * dln)) / max(lnspan, 1e-300))
                qtilde = ((F_dim * chi_arr) / (2.0 * np.pi)) * (S_arr / S0) / max(C_tilde, 1e-300)
                lever = float(np.sum(qtilde[mask] * dln))
                p_th = base['p_th']; eps = base['epsilon']; K_ref = base['K']
                delta_p1_true = - p_th * (eps ** 2) * K_ref * lever
                K_est = (-delta_p1_true) / max(p_th * (eps ** 2) * lnspan, 1e-30)
                L_qt = log_lipschitz(omega, qtilde, omega_min, omega_max_op)
                ck_act = float(omega_max_op <= c_kappa_up + 1e-12)
                return K_est, L_qt * lnspan, ck_act
            K_s, LqD_s, ck_s = one_tau(mem_probe[0] * cfg.delta_t)
            K_l, LqD_l, ck_l = one_tau(mem_probe[1] * cfg.delta_t)
            K_ref = base['K']
            bias = max(abs(K_s - K_ref) / max(abs(K_ref), 1e-30),
                       abs(K_l - K_ref) / max(abs(K_ref), 1e-30)) if (np.isfinite(K_s) and np.isfinite(K_l)) else np.nan
            grid_bias[i, j] = bias if np.isfinite(bias) else 0.0
            grid_LqD[i, j] = max(LqD_s, LqD_l)
            grid_ck[i, j]  = 0.5 * (ck_s + ck_l)
    tag = "A_phase_extended" + ("_se" if use_self_energy else "") + ("_mw" if multi_window else "")
    save_csv(fig_prefix(cfg.outdir, f"{tag}_Kbias.csv"),
             ['chi_strength_list','w0_factor_list','Kbias_grid'],
             [list(strength_list), list(w0_factor_list), [list(row) for row in grid_bias]])
    save_csv(fig_prefix(cfg.outdir, f"{tag}_LqD.csv"),
             ['chi_strength_list','w0_factor_list','LqD_grid'],
             [list(strength_list), list(w0_factor_list), [list(row) for row in grid_LqD]])
    save_csv(fig_prefix(cfg.outdir, f"{tag}_ckappa.csv"),
             ['chi_strength_list','w0_factor_list','ckappa_grid'],
             [list(strength_list), list(w0_factor_list), [list(row) for row in grid_ck]])
    fail_mask = (grid_bias > k_bias_thresh) | (grid_LqD > cfg.LqDelta_tol) | (grid_ck > 0.5)
    save_csv(fig_prefix(cfg.outdir, f"{tag}_failmask.csv"),
             ['chi_strength_list','w0_factor_list','fail_mask_grid','thresh_Kbias','thresh_LqD','thresh_ck'],
             [list(strength_list), list(w0_factor_list), [list(map(int, row)) for row in fail_mask],
              k_bias_thresh, cfg.LqDelta_tol, 0.5])
    try:
        fig, ax = plt.subplots(2,2, figsize=(12,8))
        ex = [min(strength_list), max(strength_list), min(w0_factor_list), max(w0_factor_list)]
        plt.sca(ax[0,0]); im = plt.imshow(grid_bias.T, origin='lower', aspect='auto', extent=[ex[0], ex[1], ex[2], ex[3]], cmap='magma', vmin=0.0, vmax=max(0.2, np.nanmax(grid_bias))); plt.colorbar(im, fraction=0.046, pad=0.04); plt.contour(fail_mask.T, levels=[0.5], colors='w', extent=ex, linewidths=1.5); plt.xlabel('chi_strength'); plt.ylabel('w0_factor'); plt.title('K_est bias')
        plt.sca(ax[0,1]); im = plt.imshow(grid_LqD.T, origin='lower', aspect='auto', extent=[ex[0], ex[1], ex[2], ex[3]], cmap='viridis', vmin=0.0, vmax=max(cfg.LqDelta_tol, np.nanmax(grid_LqD))); plt.colorbar(im, fraction=0.046, pad=0.04); plt.contour(fail_mask.T, levels=[0.5], colors='w', extent=ex, linewidths=1.5); plt.xlabel('chi_strength'); plt.ylabel('w0_factor'); plt.title('L_qtilde*Delta')
        plt.sca(ax[1,0]); im = plt.imshow(grid_ck.T, origin='lower', aspect='auto', extent=[ex[0], ex[1], ex[2], ex[3]], cmap='plasma', vmin=0.0, vmax=1.0); plt.colorbar(im, fraction=0.046, pad=0.04); plt.contour(fail_mask.T, levels=[0.5], colors='w', extent=ex, linewidths=1.5); plt.xlabel('chi_strength'); plt.ylabel('w0_factor'); plt.title('ckappa activation')
        plt.sca(ax[1,1]); fm = fail_mask.astype(float); im = plt.imshow(fm.T, origin='lower', aspect='auto', extent=[ex[0], ex[1], ex[2], ex[3]], cmap='binary', vmin=0.0, vmax=1.0); plt.colorbar(im, fraction=0.046, pad=0.04); plt.xlabel('chi_strength'); plt.ylabel('w0_factor'); plt.title('failure mask')
        plt.tight_layout(); queue_fig(fig, fig_prefix(cfg.outdir, f"{tag}.png"))
    except Exception:
        pass

def write_msis_report_strict2(cfg: TheoryConfig):
    base = build_geometry_and_band(cfg)
    omega_min, omega_up = base['omega_min'], base['omega_up']
    omega = nm_freq_grid(omega_min, omega_up, cfg.nm_n_omega)
    F_raw = _F_rect_dimless(omega * cfg.delta_t)
    checks = msis_checks(cfg, base, omega, F_raw)
    sigmaG_rate = 0.0; c_rate_max = 0.0
    rate_pass = (sigmaG_rate <= 0.1 + 1e-12) and (c_rate_max <= 0.1 + 1e-12)
    short_taus = cfg.nm_short_tau_list or []
    long_taus  = cfg.nm_long_tau_list or []
    theta_list = []
    for t in short_taus + long_taus:
        if t and cfg.delta_t:
            theta_list.append(min(t / cfg.delta_t, cfg.delta_t / t))
    theta_mean = float(np.mean(theta_list)) if theta_list else np.nan
    theta_min = float(np.min(theta_list)) if theta_list else np.nan
    theta_max = float(np.max(theta_list)) if theta_list else np.nan
    n_short = sum(1 for t in short_taus if (t / cfg.delta_t) <= 0.3) if short_taus else 0
    n_long = sum(1 for t in long_taus if (cfg.delta_t / max(t,1e-30)) <= 0.3) if long_taus else 0
    eps_g = 0.0
    pass_total = int(checks['eps_pass']) + int(checks['weak_pass']) + int(checks['diff_pass']) + int(checks['flat_pass']) + int(rate_pass)
    fail_total = 5 - pass_total
    save_csv(fig_prefix(cfg.outdir, "A_msis_strict_extended.csv"),
             ['epsilon','eps_pass','Gamma_tot_dt','weak_pass','tilde_a_pp','tilde_a_xx','diff_pass',
              'LqDelta','flat_pass',
              'sigmaG_rate','c_rate_max','rate_pass',
              'eps_g',
              'theta_m_mean','theta_m_min','theta_m_max','n_short_class','n_long_class',
              'pass_total','fail_total'],
             [checks['epsilon'], checks['eps_pass'], checks['Gamma_tot_dt'], checks['weak_pass'],
              checks['tilde_a_pp'], checks['tilde_a_xx'], checks['diff_pass'],
              checks['LqDelta'], checks['flat_pass'],
              sigmaG_rate, c_rate_max, rate_pass,
              eps_g,
              theta_mean, theta_min, theta_max, n_short, n_long,
              pass_total, fail_total])

