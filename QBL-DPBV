def band_C_F(omega, F, omega_min, omega_max):
    mask = (omega >= omega_min) & (omega <= omega_max)
    if not np.any(mask):
        return 1.0
    dln = np.log(omega[mask][1] / omega[mask][0])
    ln_span = _log_span(omega_min, omega_max)
    C_F = ((1.0 / (2.0 * np.pi)) * np.sum(F[mask]) * dln) / max(ln_span, 1e-30)
    return float(C_F) if np.isfinite(C_F) and C_F > 0 else 1.0


def lever_integral_log_measure(omega, F, S_over_S0, omega_min, omega_max):
    mask = (omega >= omega_min) & (omega <= omega_max)
    if not np.any(mask):
        return 0.0
    dln = np.log(omega[1] / omega[0])
    C_F = band_C_F(omega, F, omega_min, omega_max)
    q = ((F / (2.0 * np.pi)) * S_over_S0) / max(C_F, 1e-300)
    lever = float(np.sum(q[mask]) * dln)
    return lever


def lever_integral_log_with_chi(omega, F_eff, chi_arr, S_over_S0, omega_min, omega_max):
    mask = (omega >= omega_min) & (omega <= omega_max)
    if not np.any(mask):
        return 0.0, 1.0
    dln = np.log(omega[1] / omega[0])
    ln_span = _log_span(omega_min, omega_max)
    C_tilde = ((1.0 / (2.0 * np.pi)) * np.sum((F_eff * chi_arr)[mask]) * dln) / max(ln_span, 1e-30)
    C_tilde = max(float(C_tilde), 1e-300)
    qtilde = ((F_eff * chi_arr) / (2.0 * np.pi)) * S_over_S0 / C_tilde
    lever = float(np.sum(qtilde[mask]) * dln)
    return lever, C_tilde


