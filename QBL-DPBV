    def rem_le_check_values_short(tau_list):
        ratios = []
        for tm in tau_list:
            omega_star, c_kappa_up, omega_max_op = nm_operational_edge(
                cfg, F_raw, omega, omega_min, omega_up,
                lambda om, t: S_short_memory(om, t, 1.0, 0.6, cfg.delta_t), tm)
            Delta = _log_span(omega_min, omega_max_op)
            if not (np.isfinite(Delta) and Delta > THR['min_Delta']):
                continue
            if (cfg.LqDelta_tol is not None) and np.isfinite(cfg.LqDelta_tol):
                S_arr = S_short_memory(omega, tm, 1.0, 0.6, cfg.delta_t)
                S_arr = np.maximum(1e-12, S_arr)
                S0 = max(S_arr[0], 1e-300)
                L_F = log_lipschitz(omega, F_raw / (2.0 * np.pi), omega_min, omega_max_op)
                L_S = log_lipschitz(omega, (S_arr / S0), omega_min, omega_max_op)
                L_q = L_F + L_S
                lever = lever_integral_log_measure(omega, F_raw, S_arr / S0, omega_min, omega_max_op)
                bound = 0.5 * L_q * (Delta ** 2)
                if bound > 0:
                    ratios.append(abs(lever - Delta) / bound)
        return ratios
