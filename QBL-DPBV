def nonmonotone_spectrum(omega, tau_m, base='short', a=0.1, b=3.0, delta_t_ref=1.0):
    if base == 'short':
        S0 = S_short_memory(omega, tau_m, 1.0, 0.6, delta_t_ref)
    elif base == 'long':
        S0 = S_long_memory(omega, tau_m, 1.0)
    else:
        S0 = np.ones_like(omega)
    mod = 1.0 + a * np.cos(b * np.log(np.maximum(omega, 1e-30)))
    S = np.maximum(1e-12, S0 * mod)
    return S


def nonmonotone_window(F_raw, omega, a=0.1, b=3.0):
    mod = 1.0 + a * np.cos(b * np.log(np.maximum(omega, 1e-30)))
    F = np.maximum(0.0, F_raw * mod)
    return F


def run_failure_modes(cfg, omega, F_raw, omega_min, omega_up):
