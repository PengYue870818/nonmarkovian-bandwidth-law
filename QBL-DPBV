        rows.append(('nonmono_S_short', tm, omega_star, c_kappa_up, float(omega_star > c_kappa_up + 1e-12)))
    for tm in tau_l:
        S = nonmonotone_spectrum(omega, tm, base='long', a=0.15, b=4.0, delta_t_ref=cfg.delta_t)
