            for i in range(kpick):
                LqD_tilde, Delta, omega_max_op, tm = cand_sorted[i]
                S_arr = S_long_memory(omega, tm, 1.0)
                S_arr = np.maximum(1e-12, S_arr)
                _, _, lever_tilde = _LqDelta_tilde_common(S_arr, omega_max_op)
