        self.LqDelta_tol = float(LqDelta_tol)
        self.tilde_a_bound = float(tilde_a_bound)


def basic_scales(cfg: TheoryConfig):
    v_th = np.sqrt(K_B * cfg.T / max(cfg.m, 1e-300))
    p_th = cfg.m * v_th
    epsilon = HBAR / max(cfg.L_v * p_th, 1e-300)
    tau0 = cfg.L_v / max(abs(cfg.v_loc), 1e-30)
    beta = max(abs(cfg.v_loc) / max(v_th, 1e-30), 1e-12)
    tau_int = cfg.delta_t / tau0
    return v_th, p_th, epsilon, beta, tau0, tau_int


def _psf_profile(xi, mu, sigma, mode):
    if mode == "L1":
        coef = 1.0 / (np.sqrt(2.0 * np.pi) * max(sigma, 1e-30))
        return coef * np.exp(- ((xi - mu) ** 2) / max(2.0 * sigma * sigma, 1e-300))
    coef = (np.pi ** (-0.25)) * (sigma ** (-0.5))
    return coef * np.exp(- ((xi - mu) ** 2) / max(2.0 * sigma * sigma, 1e-300))


def psf_profile(cfg: TheoryConfig, xi, mu, sigma):
    return _psf_profile(xi, mu, sigma, cfg.psf_norm_mode)


def _psf_L1_to_L2_alpha(sigma):
    return (np.sqrt(2.0) * (np.pi ** 0.25) * np.sqrt(max(sigma, 1e-30)))


def compute_K_via_PSF(cfg: TheoryConfig, epsilon, xi0, d3Vtilde_func, sigma_state_dimless=None):
    C_K = 1.0 / (8.0 * np.sqrt(np.pi))
    sigma_psf = max(cfg.psf_width / max(cfg.L_v, 1e-30), 1e-12)
    mu = xi0
    xi_grid = np.linspace(mu - 12.0 * sigma_psf, mu + 12.0 * sigma_psf, 4001)
    if cfg.psf_norm_mode == "L1":
        G_L1 = _psf_profile(xi_grid, mu, sigma_psf, "L1")
        alpha = _psf_L1_to_L2_alpha(sigma_psf)
        G = alpha * G_L1
        psf_alpha = alpha
    else:
        G = psf_profile(cfg, xi_grid, mu, sigma_psf)
        psf_alpha = 1.0
    if cfg.psf_matched:
        A0 = (15.0 / 48.0)
    else:
        sigma_state = float(max(sigma_state_dimless if sigma_state_dimless is not None else epsilon, 1e-12))
        n0 = _psf_profile(xi_grid, mu, sigma_state, "L2")
        A0 = (15.0 / 48.0) * float(integrate.trapezoid(G * n0, x=xi_grid))
    d3V_vals = d3Vtilde_func(xi_grid)
    inner = float(integrate.trapezoid(G * d3V_vals, x=xi_grid))
    K = C_K * A0 * inner
    return K, xi_grid, G, d3V_vals, C_K, A0, psf_alpha


def maybe_update_sigma_G_phys_max(cfg: TheoryConfig, epsilon, v_eff):
    sigma_psf_phys = float(cfg.psf_width)
    sigma_state_phys_max = cfg.L_v * epsilon
    sigma_G_phys_max = np.sqrt(sigma_psf_phys ** 2 + sigma_state_phys_max ** 2)
    if cfg.enable_dephasing_sigma_update and cfg.Lambda_deph > 0.0:
        infl = 1.0 + min(0.1, 0.01 * np.sqrt(cfg.Lambda_deph) * cfg.delta_t)
        sigma_G_phys_max = infl * sigma_G_phys_max
    return sigma_G_phys_max


def build_geometry_and_band(cfg: TheoryConfig):
    v_th, p_th, epsilon, beta, tau0, tau_int = basic_scales(cfg)
    vloc_abs = max(abs(cfg.v_loc), 1e-30)
    if cfg.baseline_gaussian_A_eff:
        L_eff = np.sqrt(cfg.L_v ** 2 + cfg.psf_width ** 2)
        A_eff = (cfg.L_v / max(L_eff, 1e-30)) * (cfg.V0_J / (p_th * vloc_abs))
        def d3Vtilde(xi):
            return A_eff * (12.0 * xi - 8.0 * (xi ** 3)) * np.exp(-xi * xi)
    else:
        s = cfg.L_v / max(cfg.psf_width, 1e-30)
        A = (cfg.V0_J / (p_th * vloc_abs)) / np.sqrt(np.pi)
        def d3Vtilde(xi):
            return A * (-2.0 * (s ** 3) + 4.0 * (s ** 5) * (xi * xi)) * np.exp(-(s ** 2) * (xi * xi))
    xi0 = cfg.x0 / max(cfg.L_v, 1e-30)
    K_val, xi_grid_g, G_g, d3_g, C_K_val, A0_val, psf_alpha = compute_K_via_PSF(cfg, epsilon, xi0, d3Vtilde)
    v_th2 = np.sqrt(K_B * cfg.T / max(cfg.m, 1e-300))
    v_eff = max(abs(cfg.v_loc) if cfg.v_eff_mode == "loc" else v_th2, 1e-30)
    omega_min = max(1.0 / cfg.delta_t, v_eff / max(cfg.L_v, 1e-30))
    sigma_G_phys_max = maybe_update_sigma_G_phys_max(cfg, epsilon, v_eff)
    omega_geom_up = v_eff / max(sigma_G_phys_max, 1e-30)
    omega_up = float(min([c for c in [cfg.omega_sys, cfg.c_kappa / max(cfg.delta_t, 1e-30), omega_geom_up] if np.isfinite(c) and c > 0.0] + [np.inf]))
    mainlobe_cap = (2.0 * np.pi - 1e-6) / max(cfg.delta_t, 1e-30)
    omega_up = min(omega_up, mainlobe_cap)
    return dict(
        v_th=v_th, p_th=p_th, epsilon=epsilon, beta=beta, tau0=tau0, tau_int=tau_int,
        K=K_val, C_K=C_K_val, A0=A0_val, xi_grid=xi_grid_g, G=G_g, d3V=d3_g,
        omega_min=omega_min, omega_up=omega_up, sigma_G_phys_max=sigma_G_phys_max,
        mainlobe_cap=mainlobe_cap, psf_alpha=psf_alpha
    )


def nm_freq_grid(omega_min, omega_up, n):
    ln = np.linspace(np.log(omega_min), np.log(omega_up), int(max(n, 2)))
    return np.exp(ln)


def S_short_memory(omega, tau_m, S0=1.0, c_base=0.6, delta_t_ref=None):
    if delta_t_ref is None or delta_t_ref <= 0.0:
        delta_t_ref = 1.0
    tm = max(tau_m, 0.0)
    x2 = (omega * tm) ** 2
    c0 = float(c_base) * (tm / float(delta_t_ref)) ** 2
    return float(S0) * (1.0 - c0 * (x2 / (1.0 + x2)))


def S_short_memory_linear(omega, tau_m, S0=1.0, a_base=0.3, delta_t_ref=None):
    if delta_t_ref is None or delta_t_ref <= 0.0:
        delta_t_ref = 1.0
    tm = max(tau_m, 0.0)
    a = a_base * (tm / float(delta_t_ref)) ** 2
    return float(S0) * (1.0 - a * (omega ** 2))


def S_long_memory(omega, tau_m, S0=1.0):
    tm = max(tau_m, 0.0)
    x2 = (omega * tm) ** 2
    return float(S0) / (1.0 + x2)


def H_overlap_fraction(omega, F, S, omega_up):
    mask = (omega > 0) & (omega <= omega_up)
    om = omega[mask]
    integrand = F[mask] * S[mask]
    if om.size == 0:
        return np.array([omega_up], dtype=float), np.array([0.0], dtype=float), 0.0
    H = integrate.cumulative_trapezoid(integrand, om, initial=0.0) / np.pi
    total = H[-1] if H.size > 0 else 1.0
    frac = H / max(total, 1e-300)
    return om, frac, total


def Wplus_fraction(omega, F, omega_up):
    mask = (omega > 0) & (omega <= omega_up)
    om = omega[mask]
    integrand = F[mask]
    if om.size == 0:
        return np.array([omega_up], dtype=float), np.array([0.0], dtype=float), 0.0
    Wp = integrate.cumulative_trapezoid(integrand, om, initial=0.0) / (2.0 * np.pi)
    total = Wp[-1] if Wp.size > 0 else 1.0
    frac = Wp / max(total, 1e-300)
    return om, frac, total


def invert_quantile(om, frac, kappa):
    kappa = float(np.clip(kappa, 1e-9, 1.0 - 1e-9))
    return float(np.interp(kappa, frac, om))


def chi_hat_dimless(cfg: TheoryConfig, w):
    if not cfg.enable_chi or cfg.chi_mode == "flat" or not np.isfinite(cfg.chi_omega0) or cfg.chi_omega0 <= 0.0:
        return np.ones_like(w, dtype=float)
    a = float(cfg.chi_strength)
    w0 = float(cfg.chi_omega0) * cfg.delta_t
    if w0 <= 0 or not np.isfinite(w0):
        return np.ones_like(w, dtype=float)
    if cfg.chi_mode == "gauss":
        return 1.0 + a * np.exp(- (w / w0) ** 2)
    if cfg.chi_mode == "lorentz":
        return (1.0 + a) / (1.0 + (w / w0) ** 2)
    return np.ones_like(w, dtype=float)


def _log_span(omega_min, omega_max):
    return max(np.log(max(omega_max, omega_min) / max(omega_min, 1e-300)), 0.0)


def _log_average(omega, arr, a, b):
    mask = (omega >= a) & (omega <= b)
    om = omega[mask]
    if om.size < 2:
        return 0.0
    dln = np.log(om[1] / om[0])
    ln_span = _log_span(a, b)
    val = float(np.sum(arr[mask]) * dln) / max(ln_span, 1e-300)
    return val


def get_calibrated_F_for_band(cfg, omega, F_raw, omega_min, omega_max):
    w = omega
    JF_raw = (1.0 / (2.0 * np.pi)) * _log_average(w, w * F_raw, omega_min, omega_max)
    scale = 1.0
    if cfg.calibrate_J and np.isfinite(JF_raw) and JF_raw > 0:
        scale = 1.0 / JF_raw
    F_eff = F_raw * scale
    return F_eff, float(JF_raw), float(scale)


def compute_J_factors_dimless(cfg: TheoryConfig, omega, omega_min, omega_max, F_eff, chi_arr):
    if omega_max <= omega_min:
        return 1.0, 1.0, 1.0
    mask = (omega >= omega_min) & (omega <= omega_max)
    if np.count_nonzero(mask) < 2:
        return 1.0, 1.0, 1.0
    w = omega
    J_F = (1.0 / (2.0 * np.pi)) * _log_average(w, w * F_eff, omega_min, omega_max)
    num = _log_average(w, w * F_eff * chi_arr, omega_min, omega_max)
    den = max(_log_average(w, w * F_eff, omega_min, omega_max), 1e-300)
    chi_avg = float(num / den)
    J_total = float((1.0 / (2.0 * np.pi)) * num)
    return float(J_F), float(chi_avg), float(J_total)


def log_lipschitz(omega, arr, a, b):
    mask = (omega >= a) & (omega <= b)
    om = omega[mask]
    f = np.maximum(arr[mask], 1e-300)
    if om.size < 3:
        return 0.0
    ln_om = np.log(om)
    ln_f = np.log(f)
    dlnf = np.diff(ln_f)
    dlnw = np.diff(ln_om)
    slope = np.abs(dlnf / np.maximum(dlnw, 1e-300))
    return float(np.max(slope)) if slope.size > 0 else 0.0


def nm_operational_edge(cfg, F, omega_grid, omega_min, omega_up, S_func, tau_m):
    om = omega_grid
    S = S_func(om, tau_m)
    omH, Hfrac, _ = H_overlap_fraction(om, F, S, omega_up)
    omega_star = invert_quantile(omH, Hfrac, cfg.kappa_coverage)
    omW, Wfrac, _ = Wplus_fraction(om, F, omega_up)
    c_kappa_up = invert_quantile(omW, Wfrac, cfg.kappa_coverage)
    v_th = np.sqrt(K_B * cfg.T / max(cfg.m, 1e-300))
    epsilon = HBAR / max(cfg.L_v * (cfg.m * v_th), 1e-300)
    v_eff = max(abs(cfg.v_loc) if cfg.v_eff_mode == "loc" else v_th, 1e-30)
    sigma_G_phys_max = maybe_update_sigma_G_phys_max(cfg, epsilon, v_eff)
    c_in = v_eff / max(sigma_G_phys_max, 1e-30)
    mainlobe_cap = (2.0 * np.pi - 1e-6) / max(cfg.delta_t, 1e-30)
    omega_up_eff = min(omega_up, mainlobe_cap)
    candidates = [omega_star, c_kappa_up, c_in, cfg.omega_sys, cfg.c_kappa / max(cfg.delta_t, 1e-30), omega_up_eff]
    candidates = [c for c in candidates if np.isfinite(c) and c > 0]
    omega_max_op = min(candidates) if candidates else omega_up_eff
    return float(omega_star), float(c_kappa_up), float(omega_max_op)


def maybe_legend():
    ax = plt.gca()
    handles, labels = ax.get_legend_handles_labels()
    if len(labels) > 0:
        ax.legend(loc='best', fontsize=10, frameon=False)


def mark_vertical(x, color, label=None, alpha=0.9):
    plt.axvline(x, color=color, ls='--', lw=1.6, alpha=alpha, label=label, zorder=4)


def band_patch(x0, x1, y0, y1, color, alpha=0.12, label=None):
    plt.fill_between([x0, x1], [y0, y0], [y1, y1], color=color, alpha=alpha, label=label, zorder=1)


def plot_nm_edge_show(cfg, tag, title, omega, F, tau_list, S_func, omega_min, omega_up):
    fig, ax = plt.subplots(1, 2, figsize=(11, 4.6))
    colors = ['#4C78A8', '#E45756', '#72B7B2', '#F58518', '#B279A2', '#9C755F', '#59A14F', '#EDC948', '#B07AA1', '#FF9DA7']
    curves_rows = {'panel': [], 'curve': [], 'tau_m_s': [], 'omega': [], 'value': [], 'kind': []}
    summary_rows = {'tau_m_s': [], 'omega_star': [], 'c_kappa_up': [], 'omega_max_op': [], 'Omega0': [], 'kappa': []}
    plt.sca(ax[0])
    S1 = np.ones_like(omega)
    omH0, frac0, _ = H_overlap_fraction(omega, F, S1, omega_up)
    plt.semilogx(omH0, frac0, color='k', lw=2.2, label='Markov baseline', zorder=5)
    for o, v in zip(omH0, frac0):
        curves_rows['panel'].append('left'); curves_rows['curve'].append('Markov'); curves_rows['tau_m_s'].append(np.nan); curves_rows['omega'].append(o); curves_rows['value'].append(v); curves_rows['kind'].append('H_frac')
    omW0, Wfrac0, _ = Wplus_fraction(omega, F, omega_up)
    Omega0 = invert_quantile(omW0, Wfrac0, cfg.kappa_coverage)
    mark_vertical(Omega0, 'k', label='Omega0 (W+ quantile)')
    for o, v in zip(omW0, Wfrac0):
        curves_rows['panel'].append('left'); curves_rows['curve'].append('Wplus'); curves_rows['tau_m_s'].append(np.nan); curves_rows['omega'].append(o); curves_rows['value'].append(v); curves_rows['kind'].append('Wplus_frac')
    for i, tm in enumerate(tau_list):
        S = S_func(omega, tm)
        omega_star, c_kappa_up, omega_max_op = nm_operational_edge(cfg, F, omega, omega_min, omega_up, S_func, tm)
        band_patch(omega_min, omega_max_op, 0.0, 1.0, colors[i % len(colors)], alpha=0.12)
        omH, frac, _ = H_overlap_fraction(omega, F, S, omega_up)
        plt.semilogx(omH, frac, lw=2.0, color=colors[i % len(colors)], label=f'tau={tm:.2e}s', zorder=3)
        mark_vertical(omega_star, colors[i % len(colors)])
        for o, v in zip(omH, frac):
            curves_rows['panel'].append('left'); curves_rows['curve'].append('H_frac'); curves_rows['tau_m_s'].append(tm); curves_rows['omega'].append(o); curves_rows['value'].append(v); curves_rows['kind'].append('H_frac')
        summary_rows['tau_m_s'].append(tm); summary_rows['omega_star'].append(omega_star); summary_rows['c_kappa_up'].append(c_kappa_up); summary_rows['omega_max_op'].append(omega_max_op); summary_rows['Omega0'].append(Omega0); summary_rows['kappa'].append(cfg.kappa_coverage)
    plt.axhline(cfg.kappa_coverage, color='gray', ls=':', lw=1.2, label=f'kappa={cfg.kappa_coverage:g}', zorder=2)
    plt.xlabel('omega [rad/s]'); plt.ylabel('H(Omega)/H(Omega_up)')
    plt.title('Edge selection and coverage')
    maybe_legend()
    plt.sca(ax[1])
    plt.loglog(omega, F / (2.0 * np.pi), color='k', lw=1.8, label='F/(2pi)', zorder=5)
    for i, tm in enumerate(tau_list[:min(6, len(tau_list))]):
        S = S_func(omega, tm)
        S0 = max(S[0], 1e-300)
        plt.loglog(omega, S / S0, color=colors[i % len(colors)], lw=1.6, label=f'S/S0 tau={tm:.2e}s', zorder=3)
        for o, v in zip(omega, (S / S0)):
            curves_rows['panel'].append('right'); curves_rows['curve'].append('S_over_S0'); curves_rows['tau_m_s'].append(tm); curves_rows['omega'].append(o); curves_rows['value'].append(v); curves_rows['kind'].append('S_over_S0')
    for o, v in zip(omega, F / (2.0 * np.pi)):
        curves_rows['panel'].append('right'); curves_rows['curve'].append('F_over_2pi'); curves_rows['tau_m_s'].append(np.nan); curves_rows['omega'].append(o); curves_rows['value'].append(v); curves_rows['kind'].append('F_over_2pi')
    plt.axvline(omega_min, color='gray', ls='-.', lw=1.4, label='omega_min', zorder=2)
    plt.axvline(omega_up, color='gray', ls='--', lw=1.4, label='Omega_up', zorder=2)
    plt.xlabel('omega [rad/s]'); plt.ylabel('window and spectrum')
    plt.title('Window and memory spectrum')
    maybe_legend()
    plt.suptitle(title, y=1.02)
    plt.tight_layout()
    png = fig_prefix(cfg.outdir, f"{tag}.png")
    csv_curves = fig_prefix(cfg.outdir, f"{tag}_curves.csv")
