def finite_mean(arr):
    a = np.array(arr, dtype=float)
    m = np.isfinite(a)
    if np.any(m):
        return float(np.mean(a[m]))
    return np.nan


def msis_checks(cfg: TheoryConfig, base, omega, F_raw):
    v_th, p_th, epsilon, beta, tau0, tau_int = base['v_th'], base['p_th'], base['epsilon'], base['beta'], base['tau0'], base['tau_int']
    tilde_a_pp = (cfg.Dpp_bg * (cfg.L_v / max(abs(cfg.v_loc), 1e-30))) / max(p_th ** 2, 1e-300)
    tilde_a_xx = (cfg.Dxx_bg * (cfg.L_v / max(abs(cfg.v_loc), 1e-30))) / max(cfg.L_v ** 2, 1e-300)
    Gamma_tot_dt = float(min(0.25, max(tilde_a_pp, tilde_a_xx)))
    omega_min, omega_up = base['omega_min'], base['omega_up']
    ln_span = _log_span(omega_min, omega_up)
    L_F = log_lipschitz(omega, F_raw / (2.0 * np.pi), omega_min, omega_up)
    LqDelta = float(L_F * ln_span)
    checks = dict(
        epsilon=float(epsilon), eps_pass=(epsilon <= cfg.eps_max + 1e-12),
        Gamma_tot_dt=Gamma_tot_dt, weak_pass=(Gamma_tot_dt <= 0.1 + 1e-12),
        mem_short_ratio=0.0, mem_long_ratio=0.0,
        slow_param_rate=0.0, slow_pass=True,
        sigmaG_rate=0.0, sigmaG_pass=True,
        tilde_a_pp=float(tilde_a_pp), tilde_a_xx=float(tilde_a_xx),
        diff_pass=(tilde_a_pp <= cfg.tilde_a_bound + 1e-12) and (tilde_a_xx <= cfg.tilde_a_bound + 1e-12),
        LqDelta=LqDelta, flat_pass=(LqDelta <= cfg.LqDelta_tol + 1e-12)
    )
    return checks


def compute_core_metrics(cfg, collect_alpha=False):
    base = build_geometry_and_band(cfg)
    v_th = base['v_th']; p_th = base['p_th']; epsilon = base['epsilon']
    omega_min = base['omega_min']; omega_up = base['omega_up']
    omega = nm_freq_grid(omega_min, omega_up, cfg.nm_n_omega)
    F_raw = filter_rectangular_double_sided(omega, cfg.delta_t)
    short_taus = cfg.nm_short_tau_list or list(np.linspace(0.02, 0.8, 64) * cfg.delta_t)
    long_taus = cfg.nm_long_tau_list or list(np.linspace(3.0, 60.0, 64) * cfg.delta_t)
    def S_sm(om, tm): return S_short_memory(om, tm, 1.0, 0.6, cfg.delta_t)
    omW, Wfrac, _ = Wplus_fraction(omega, F_raw, omega_up)
    Omega0 = invert_quantile(omW, Wfrac, cfg.kappa_coverage)
    xs, ys = [], []
    K_ests = []
    alphas = []
    E_le_vals = []
    collapse_biases = []
    for tm in short_taus:
        omega_star, c_kappa_up, omega_max_op = nm_operational_edge(cfg, F_raw, omega, omega_min, omega_up, S_sm, tm)
        xs.append((tm / cfg.delta_t) ** 2); ys.append(Omega0 - omega_star)
        S_arr = S_sm(omega, tm); S0 = max(S_arr[0], 1e-30)
        lever_nm = lever_integral_log_measure(omega, F_raw, S_arr / S0, omega_min, omega_max_op)
        ln_band = _log_span(omega_min, omega_max_op)
        if ln_band > 0:
            delta_p1_num = - p_th * (epsilon ** 2) * base['K'] * lever_nm
            K_ests.append((-delta_p1_num) / (p_th * (epsilon ** 2) * ln_band))
            collapse_biases.append(lever_nm - ln_band)
        if collect_alpha:
            if ln_band > 0:
                delta_p1_num = - p_th * (epsilon ** 2) * base['K'] * lever_nm
                alphas.append(((-delta_p1_num) / (p_th * (epsilon ** 2) * base['K'])) / ln_band)
            L_F = log_lipschitz(omega, F_raw / (2.0 * np.pi), omega_min, omega_max_op)
            L_S = log_lipschitz(omega, (S_arr / S0), omega_min, omega_max_op)
            L_q = L_F + L_S
            E_le = p_th * (epsilon ** 2) * base['K'] * (L_q / 2.0) * (ln_band ** 2)
            E_le_vals.append(E_le)
    eta, _, _, _, _ = _quad_fit_through_origin(xs, ys)
    gk = np.tan(np.pi * cfg.kappa_coverage / 2.0)
    g_errs = []
    for tm in long_taus:
        omega_star, _, _ = nm_operational_edge(cfg, F_raw, omega, omega_min, omega_up, S_long_memory, tm)
        if gk > 0:
            g_errs.append(abs(omega_star * tm - gk) / gk)
    out = dict(
        eta_short=float(eta) if np.isfinite(eta) else np.nan,
        K_mean=finite_mean(K_ests),
        collapse_bias=finite_mean(collapse_biases),
        gk_long_err=finite_mean(g_errs),
    )
    if collect_alpha:
        out['alpha_mean'] = finite_mean(alphas)
        out['alpha_std'] = float(np.nanstd(np.array(alphas, dtype=float))) if np.any(np.isfinite(alphas)) else np.nan
        out['E_le_mean'] = finite_mean(E_le_vals)
    return out


def run_convergence_tests(cfg, rel_tol=0.80):
    base_cfg = copy.deepcopy(cfg)
    metrics_base = compute_core_metrics(base_cfg)
    fine_cfg = copy.deepcopy(cfg); fine_cfg.nm_n_omega = max(2 * cfg.nm_n_omega, 4096)
    metrics_fine = compute_core_metrics(fine_cfg)
    dense_cfg = copy.deepcopy(cfg); dense_cfg.nm_short_tau_list = list(np.linspace(0.0, 0.3, 96) * cfg.delta_t)
    metrics_dense = compute_core_metrics(dense_cfg)
    def rel_diff(a, b):
        if not (np.isfinite(a) and np.isfinite(b)) or (abs(a) + abs(b) < 1e-30): return np.nan
        return abs(a - b) / max(abs(a), 1e-30)
    rows = []
    for name in ['eta_short', 'K_mean', 'collapse_bias', 'gk_long_err']:
        a = metrics_base[name]; b = metrics_fine[name]; c = metrics_dense[name]
        r1 = rel_diff(a, b); r2 = rel_diff(a, c)
        rows.append((name, a, b, c, r1, r2, (r1 <= rel_tol) and (r2 <= rel_tol)))
    csvp = fig_prefix(cfg.outdir, "nm_convergence.csv")
    save_csv(csvp, ['metric','baseline','omega_x2','tau_x2','rel_diff_omega','rel_diff_tau','pass'],
             [[r[0] for r in rows], [r[1] for r in rows], [r[2] for r in rows], [r[3] for r in rows], [r[4] for r in rows], [r[5] for r in rows], [r[6] for r in rows]])
    try:
        fig = plt.figure(figsize=(7.6,4.2))
        x = np.arange(len(rows))
        rel1 = [r[4] if np.isfinite(r[4]) else 0.0 for r in rows]
        rel2 = [r[5] if np.isfinite(r[5]) else 0.0 for r in rows]
        width = 0.35
        plt.bar(x - width/2, rel1, width, label='omega x2')
        plt.bar(x + width/2, rel2, width, label='tau x2')
        plt.axhline(rel_tol, color='r', ls='--', lw=1.2)
        plt.xticks(x, [r[0] for r in rows], rotation=20)
        plt.ylabel('relative change'); plt.title('Convergence'); plt.legend(frameon=False)
        plt.tight_layout()
        queue_fig(fig, fig_prefix(cfg.outdir, "nm_convergence.png"))
    except Exception:
        pass


