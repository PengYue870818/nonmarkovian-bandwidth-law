def msis_long_edge_omega_star(omega_up, tau_m, kappa):
    t = float(max(tau_m, 1e-30))
    xup = float(omega_up * t)
    if not np.isfinite(xup) or xup <= 0.0:
        return np.nan
    ang = np.arctan(xup)
    if ang <= 1e-12:
        return np.nan
    val = np.tan(float(kappa) * ang) / t
    return float(val) if np.isfinite(val) and val > 0 else np.nan

def nm_operational_edge_msis_long(cfg, F, omega_grid, omega_min, omega_up, tau_m):
    om = omega_grid
    omega_star = msis_long_edge_omega_star(omega_up, tau_m, cfg.kappa_coverage)
    omW, Wfrac, _ = Wplus_fraction(om, F, omega_up)
    c_kappa_up = invert_quantile(omW, Wfrac, cfg.kappa_coverage)
    v_th = np.sqrt(K_B * cfg.T / max(cfg.m, 1e-300))
    epsilon = HBAR / max(cfg.L_v * (cfg.m * v_th), 1e-300)
    v_eff = max(abs(cfg.v_loc) if cfg.v_eff_mode == "loc" else v_th, 1e-30)
    sigma_G_phys_max = maybe_update_sigma_G_phys_max(cfg, epsilon, v_eff)
    c_in = v_eff / max(sigma_G_phys_max, 1e-30)
    mainlobe_cap = (2.0 * np.pi - 1e-6) / max(cfg.delta_t, 1e-30)
    omega_up_eff = min(omega_up, mainlobe_cap)
    candidates = [omega_star, c_kappa_up, c_in, cfg.omega_sys, cfg.c_kappa / max(cfg.delta_t, 1e-30), omega_up_eff]
    candidates = [c for c in candidates if np.isfinite(c) and c > 0]
    omega_max_op = min(candidates) if candidates else omega_up_eff
    return float(omega_star), float(c_kappa_up), float(omega_max_op)

def validate_paper_claims(cfg: TheoryConfig, out_name="validation_report_msis.csv"):
    THR = {
        'ineq_min_gap_short': 1e-8,
        'ineq_min_gap_long': 1e-4,
        'short_R2': 0.995,
        'short_CI_pos': 0.0,
        'long_max_rel': 0.01,
        'Klock_max_rel': 0.03,
        'Klock_LqDelta_tol': 0.20,
        'Klock_LqDelta_tol_fb': 0.30,
        'Klock_LqDelta_tol_fb2': 0.50,
        'rem_le_factor': 1.25,
        'tvf_max_norm_err': 5e-3,
        'convergence_rel': 0.80,
        'min_Delta': 1e-4,
        'LM_slow_thresh': 50.0,
        'LM_slow_thresh_fb': 150.0,
        'LM_slow_thresh_fb2': 100.0
    }
    def rec(claim, metric, val, thr, ok):
        rows['claim'].append(claim)
        rows['metric'].append(metric)
        rows['value'].append(val)
        rows['threshold'].append(thr)
        rows['pass'].append(bool(ok))
    def q(arr, p, default=np.nan):
        arr = np.asarray(arr, dtype=float)
        arr = arr[np.isfinite(arr)]
        if arr.size == 0:
            return default
        p = min(max(p, 0.0), 1.0)
        try:
            return float(np.nanquantile(arr, p))
        except Exception:
            return default
    def gap_interior(omH, Hfrac, omW, Wfrac, trim_frac=0.15):
        if (omH.size < 4) or (omW.size < 4):
            return np.nan
        i0 = int(np.floor(trim_frac * omH.size))
        i1 = int(np.ceil((1.0 - trim_frac) * omH.size))
        if i1 <= i0 + 1:
            return np.nan
        omc = omH[i0:i1]
        Hc = np.interp(omc, omH, Hfrac)
        Wc = np.interp(omc, omW, Wfrac)
        return float(np.min(Hc - Wc))
    def limiter_active_kind(omega_star, c_kappa_up, c_in, omega_sys, c_kappa_dt, omega_up_eff):
        cands = [omega_star, c_kappa_up, c_in, omega_sys, c_kappa_dt, omega_up_eff]
        labs = ['omega_star','c_kappa_up','c_in','omega_sys','c_kappa/dt','mainlobe']
        vals = [(v, l) for v, l in zip(cands, labs) if np.isfinite(v) and v > 0]
        if not vals:
            return None
        mn = min(vals, key=lambda x: x[0])[0]
        tol = 1e-9 * max(mn, 1.0)
        act = [l for v, l in vals if abs(v - mn) <= tol]
        return act[0] if act else None
    def phys_limits(cfg):
        v_th = np.sqrt(K_B * cfg.T / max(cfg.m, 1e-300))
        eps = HBAR / max(cfg.L_v * (cfg.m * v_th), 1e-300)
        v_eff = max(abs(cfg.v_loc) if cfg.v_eff_mode == "loc" else v_th, 1e-30)
        sigma_G = maybe_update_sigma_G_phys_max(cfg, eps, v_eff)
        c_in = v_eff / max(sigma_G, 1e-30)
        return v_th, eps, v_eff, c_in
    def _LqDelta_tilde_common(S_arr, omega_max_op):
        S0 = max(S_arr[0], 1e-300)
        F_eff, JF_raw, _ = get_calibrated_F_for_band(cfg, omega, F_raw, omega_min, omega_max_op)
        lever_tilde, C_tilde = lever_integral_log_with_chi(omega, F_eff, chi_full, S_arr / S0, omega_min, omega_max_op)
        qtilde = ((F_eff * chi_full) / (2.0 * np.pi)) * (S_arr / S0) / max(C_tilde, 1e-300)
        L_qtilde = log_lipschitz(omega, qtilde, omega_min, omega_max_op)
        Delta = _log_span(omega_min, omega_max_op)
        return float(L_qtilde * Delta), float(Delta), float(lever_tilde)
    def LqDelta_for_short(tm):
        omega_star, c_kappa_up, omega_max_op = nm_operational_edge(
            cfg, F_raw, omega, omega_min, omega_up,
            lambda om, t: S_short_memory(om, t, 1.0, 0.6, cfg.delta_t), tm)
        Delta = _log_span(omega_min, omega_max_op)
        if not (np.isfinite(Delta) and Delta > THR['min_Delta']):
            return np.nan, np.nan, None, np.nan, np.nan
        S_arr = S_short_memory(omega, tm, 1.0, 0.6, cfg.delta_t)
        S_arr = np.maximum(1e-12, S_arr)
        LqD_tilde, Delta, lever_tilde = _LqDelta_tilde_common(S_arr, omega_max_op)
        v_th, eps, v_eff, c_in = phys_limits(cfg)
        act = limiter_active_kind(omega_star, c_kappa_up, c_in, cfg.omega_sys, cfg.c_kappa / max(cfg.delta_t, 1e-30), mainlobe_cap)
        return float(LqD_tilde), float(Delta), act, float(omega_star), float(omega_max_op)
    def LqDelta_for_long_msis_phys(tm):
        gk = np.tan(np.pi * cfg.kappa_coverage / 2.0)
        omega_star = gk / max(tm, 1e-30)
        v_th, eps, v_eff, c_in = phys_limits(cfg)
        omega_up_phys = min(c_in, cfg.omega_sys)
        omega_max_op = min(omega_star, omega_up_phys) if np.isfinite(omega_up_phys) and omega_up_phys > 0 else omega_star
        Delta = _log_span(omega_min, omega_max_op)
        if not (np.isfinite(Delta) and Delta > THR['min_Delta']):
            return np.nan, np.nan, None, np.nan, np.nan
        S_arr = S_long_memory(omega, tm, 1.0)
        S_arr = np.maximum(1e-12, S_arr)
        LqD_tilde, Delta, lever_tilde = _LqDelta_tilde_common(S_arr, omega_max_op)
        act = limiter_active_kind(omega_star, np.inf, c_in, cfg.omega_sys, np.inf, np.inf)
        return float(LqD_tilde), float(Delta), act, float(omega_star), float(omega_max_op)
    def K_lock_rel_errors_short(tau_list, tol):
        errs = []
        lqd_vals = []
        cand_all = []
        for tm in tau_list:
            LqD_tilde, Delta, act, _, omega_max_op = LqDelta_for_short(tm)
            if not (np.isfinite(LqD_tilde) and np.isfinite(Delta)):
                continue
            lqd_vals.append(LqD_tilde)
            cand_all.append((LqD_tilde, Delta, omega_max_op, tm))
        if cand_all:
            cand_sorted = sorted(cand_all, key=lambda x: x[0])
            n = len(cand_sorted)
            base = max(1, int(n * 0.10))
            kpick = min(n, max(3, min(12, base)))
            for i in range(kpick):
                LqD_tilde, Delta, omega_max_op, tm = cand_sorted[i]
                S_arr = S_short_memory(omega, tm, 1.0, 0.6, cfg.delta_t)
                S_arr = np.maximum(1e-12, S_arr)
                _, _, lever_tilde = _LqDelta_tilde_common(S_arr, omega_max_op)
                errs.append(abs(lever_tilde / Delta - 1.0))
