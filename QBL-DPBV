def ensure_dir(d):
    if not os.path.isdir(d):
        os.makedirs(d, exist_ok=True)
    return d


def save_csv(path, headers, columns):
    arrays = []
    lens = []
    for c in columns:
        if np.isscalar(c) and not isinstance(c, str):
            arr = np.array([c])
        else:
            arr = np.array(c, dtype=object).reshape(-1)
        arrays.append(arr)
        lens.append(arr.shape[0])
    n = max(lens) if lens else 0
    bcols = []
    for arr in arrays:
        if arr.shape[0] == n:
            bcols.append(arr)
        elif arr.shape[0] == 1 and n > 1:
            bcols.append(np.full(n, arr[0], dtype=object))
        elif arr.shape[0] == 0 and n > 0:
            bcols.append(np.full(n, np.nan, dtype=object))
        else:
            pad_len = n - arr.shape[0]
            if pad_len > 0:
                arr = np.concatenate([arr, np.full(pad_len, np.nan, dtype=object)], axis=0)
            bcols.append(arr)
    ensure_dir(os.path.dirname(path))
    with open(path, "w", newline="") as f:
        w = csv.writer(f)
        w.writerow(headers)
        for i in range(n):
            row = []
            for col in bcols:
                val = col[i] if col.shape[0] > 0 else np.nan
                try:
                    row.append(float(val))
                except (TypeError, ValueError):
                    row.append(str(val))
            w.writerow(row)


def fig_prefix(outdir, tag):
    return os.path.join(outdir, tag)


def queue_fig(fig, path):
    ensure_dir(os.path.dirname(path))
    PENDING_FIGS.append((fig, path))


def flush_all_figs():
    for fig, path in PENDING_FIGS:
        fig.savefig(path, dpi=220, bbox_inches='tight')
        plt.close(fig)
    PENDING_FIGS.clear()


def filter_rectangular_double_sided(omega, delta_t):
    w = np.asarray(omega, dtype=float) * float(delta_t)
    w2 = np.maximum(w * w, 1e-300)
    return 4.0 * (np.sin(0.5 * w) ** 2) / w2


class TheoryConfig:
    def __init__(
            self,
            T=200e-9, m=M_RB, L_v=10e-6, v_loc=2.0e-2, delta_t=2.0e-3,
            psf_width=0.5e-6, V0_J=K_B * 0.39e-6, x0=0.0, p0=0.0,
            Dpp_bg=0.0, Dxx_bg=0.0, Gamma_phi_bg=0.0,
            alpha_coll=2.0, lambda_opt=780e-9, Gamma_s_const=10.0, kappa_phi_sq=1.0,
            omega_sys=np.inf, c_kappa=4.0, v_eff_mode="th",
            psf_matched=True, baseline_gaussian_A_eff=True,
            outdir="figs_nm_mmsis", seed=0, psf_norm_mode="L2",
            kappa_coverage=0.8, nm_n_omega=32768, nm_short_tau_list=None, nm_long_tau_list=None,
            enable_chi=True, chi_mode="flat", chi_strength=0.0, chi_omega0=np.inf,
            enable_flatness=True,
            enable_dephasing_sigma_update=False, Lambda_deph=0.0,
            calibrate_J=True,
            eps_max=0.2, LqDelta_tol=0.1, tilde_a_bound=0.5
    ):
        self.T = float(T); self.m = float(m); self.L_v = float(L_v)
        self.v_loc = float(v_loc); self.delta_t = float(delta_t)
        self.psf_width = float(psf_width); self.V0_J = float(V0_J)
