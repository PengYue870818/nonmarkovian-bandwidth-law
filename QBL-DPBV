        self.Gamma_phi_bg = float(Gamma_phi_bg)
        self.alpha_coll = float(alpha_coll); self.lambda_opt = float(lambda_opt)
        self.Gamma_s_const = float(Gamma_s_const); self.kappa_phi_sq = float(kappa_phi_sq)
